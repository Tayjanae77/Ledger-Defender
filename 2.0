// ── CHARACTER SELECT ─────────────────────────────────────────
function pickChar(kind){
  selectedChar=kind;
  document.getElementById('copt-boy').classList.toggle('picked',kind==='boy');
  document.getElementById('copt-girl').classList.toggle('picked',kind==='girl');
  document.getElementById('ring-boy').style.opacity=kind==='boy'?'1':'0';
  document.getElementById('ring-girl').style.opacity=kind==='girl'?'1':'0';
}

// Draw preview dolls on the char-select canvases
function renderCharPreviews(){
  ['boy','girl'].forEach(kind=>{
    const cv=document.getElementById('preview'+kind.charAt(0).toUpperCase()+kind.slice(1));
    if(!cv)return;
    const ctx=cv.getContext('2d');
    ctx.clearRect(0,0,52,68);
    // Draw doll centered: s=12 so body spans roughly -22..+22 wide, -25..+20 tall
    ctx.save();ctx.translate(26,42);
    drawDoll(ctx,12,kind,0);
    ctx.restore();
  });
}

// ── CREEPY MUSIC ENGINE (Web Audio) ──────────────────────────
let audioCtx=null, musicNodes=[], musicRunning=false;

function startMusic(){
  if(musicRunning) return;
  try{
    if(!audioCtx) audioCtx=new(window.AudioContext||window.webkitAudioContext)();
    // AudioContext may be suspended until a user gesture — resume it
    const go=()=>{ musicRunning=true; playCreepyAmbience(); };
    if(audioCtx.state==='suspended') audioCtx.resume().then(go); else go();
  }catch(e){ console.warn('Audio failed:',e); }
}

function stopMusic(){
  musicRunning=false;
  musicNodes.forEach(n=>{try{n.stop();}catch(e){}});
  musicNodes=[];
}

function playCreepyAmbience(){
  if(!audioCtx||!musicRunning) return;
  const master=audioCtx.createGain();
  master.gain.setValueAtTime(0.0, audioCtx.currentTime);
  master.connect(audioCtx.destination);
  master.gain.linearRampToValueAtTime(0.55, audioCtx.currentTime+3);

  // ── Layer 1: Drone — low ominous hum ──
  const droneFreqs=[36.7,55.0,73.4];
  droneFreqs.forEach((freq,i)=>{
    const osc=audioCtx.createOscillator();
    const g=audioCtx.createGain();
    const filt=audioCtx.createBiquadFilter();
    osc.type='sawtooth';
    osc.frequency.value=freq;
    osc.frequency.setValueAtTime(freq,audioCtx.currentTime);
    osc.frequency.linearRampToValueAtTime(freq*(1+.005*Math.sin(i)),audioCtx.currentTime+8);
    g.gain.value=0.08/(i+1);
    filt.type='lowpass';filt.frequency.value=300+i*80;filt.Q.value=2;
    osc.connect(filt);filt.connect(g);g.connect(master);
    osc.start();
    musicNodes.push(osc);
    // subtle LFO tremolo
    const lfo=audioCtx.createOscillator();
    const lfoG=audioCtx.createGain();
    lfo.frequency.value=0.08+i*0.03;lfo.type='sine';
    lfoG.gain.value=0.03;
    lfo.connect(lfoG);lfoG.connect(g.gain);
    lfo.start();musicNodes.push(lfo);
  });

  // ── Layer 2: Heartbeat-style low thump every ~2.2s ──
  const scheduleThump=()=>{
    if(!musicRunning) return;
    const now=audioCtx.currentTime;
    // Double thump (lub-dub)
    [0, 0.22].forEach((delay,i)=>{
      const osc=audioCtx.createOscillator();
      const g=audioCtx.createGain();
      const filt=audioCtx.createBiquadFilter();
      osc.type='sine';osc.frequency.value=55;
      g.gain.setValueAtTime(0,now+delay);
      g.gain.linearRampToValueAtTime(i===0?.28:.18,now+delay+.04);
      g.gain.exponentialRampToValueAtTime(.001,now+delay+.28);
      filt.type='lowpass';filt.frequency.value=160;
      osc.connect(filt);filt.connect(g);g.connect(master);
      osc.start(now+delay);osc.stop(now+delay+.3);
      musicNodes.push(osc);
    });
    setTimeout(scheduleThump, 2200+Math.random()*400);
  };
  setTimeout(scheduleThump,800);

  // ── Layer 3: High eerie sine melody (pentatonic minor) ──
  const eerie=[130.8,155.6,174.6,207.7,233.1,261.6,311.1,349.2];
  const playEerieNote=()=>{
    if(!musicRunning) return;
    const now=audioCtx.currentTime;
    const freq=eerie[Math.floor(Math.random()*eerie.length)]*(Math.random()<.3?2:1);
    const osc=audioCtx.createOscillator();
    const g=audioCtx.createGain();
    const rev=audioCtx.createConvolver();
    osc.type='sine';osc.frequency.value=freq;
    const dur=1.2+Math.random()*2.5;
    g.gain.setValueAtTime(0,now);
    g.gain.linearRampToValueAtTime(0.055+Math.random()*.03,now+.15);
    g.gain.exponentialRampToValueAtTime(.001,now+dur);
    osc.connect(g);g.connect(master);
    osc.start(now);osc.stop(now+dur+.1);
    musicNodes.push(osc);
    setTimeout(playEerieNote,(800+Math.random()*3200));
  };
  setTimeout(playEerieNote,1500);

  // ── Layer 4: Whisper noise bursts ──
  const playWhisper=()=>{
    if(!musicRunning) return;
    const now=audioCtx.currentTime;
    const buf=audioCtx.createBuffer(1,audioCtx.sampleRate*.4,audioCtx.sampleRate);
    const data=buf.getChannelData(0);
    for(let i=0;i<data.length;i++) data[i]=(Math.random()*2-1)*.35;
    const src2=audioCtx.createBufferSource();
    src2.buffer=buf;
    const filt=audioCtx.createBiquadFilter();
    filt.type='bandpass';filt.frequency.value=2200+Math.random()*800;filt.Q.value=8;
    const g=audioCtx.createGain();
    g.gain.setValueAtTime(0,now);
    g.gain.linearRampToValueAtTime(.04,now+.05);
    g.gain.exponentialRampToValueAtTime(.001,now+.38);
    src2.connect(filt);filt.connect(g);g.connect(master);
    src2.start(now);
    musicNodes.push(src2);
    setTimeout(playWhisper,(4000+Math.random()*6000));
  };
  setTimeout(playWhisper,3000);

  // ── Layer 5: Occasional low string scrape ──
  const playScrape=()=>{
    if(!musicRunning) return;
    const now=audioCtx.currentTime;
    const osc=audioCtx.createOscillator();
    const g=audioCtx.createGain();
    const filt=audioCtx.createBiquadFilter();
    osc.type='sawtooth';
    const startF=80+Math.random()*40;
    osc.frequency.setValueAtTime(startF,now);
    osc.frequency.linearRampToValueAtTime(startF*(0.7+Math.random()*.5),now+1.5);
    const dur=1+Math.random();
    g.gain.setValueAtTime(0,now);g.gain.linearRampToValueAtTime(.1,now+.2);g.gain.exponentialRampToValueAtTime(.001,now+dur);
    filt.type='bandpass';filt.frequency.value=300;filt.Q.value=3;
    osc.connect(filt);filt.connect(g);g.connect(master);
    osc.start(now);osc.stop(now+dur+.1);
    musicNodes.push(osc);
    setTimeout(playScrape,5000+Math.random()*8000);
  };
  setTimeout(playScrape,2500);
}

// ── GAMEPAD SUPPORT ──────────────────────────────────────────
// Works with Xbox, PS, and most generic controllers.
// Left stick / D-pad  → move
// Right stick         → manual aim override (optional)
// A / Cross / RT      → manual fire (auto-fire handles it anyway)
// Start               → confirm on screens
let gpAimOverride = false;

function pollGamepad(p, dt){
  const gps = navigator.getGamepads ? navigator.getGamepads() : [];
  const gp = [...gps].find(g=>g&&g.connected);
  if(!gp) return;

  const dead = 0.18; // deadzone

  // ── Left stick / D-pad → movement ──
  const lx = Math.abs(gp.axes[0])>dead ? gp.axes[0] : 0;
  const ly = Math.abs(gp.axes[1])>dead ? gp.axes[1] : 0;
  // D-pad buttons (indices 12-15 on standard mapping)
  const dpU = gp.buttons[12]?.pressed, dpD = gp.buttons[13]?.pressed;
  const dpL = gp.buttons[14]?.pressed, dpR = gp.buttons[15]?.pressed;

  let gdx = lx + (dpR?1:0) - (dpL?1:0);
  let gdy = ly + (dpD?1:0) - (dpU?1:0);
  if(gdx&&gdy){gdx*=0.707;gdy*=0.707;}
  if(gdx||gdy){
    p.x=clamp(p.x+gdx*pStats.spd*dt*1.1, PX1+p.size, PX2-p.size);
    p.y=clamp(p.y+gdy*pStats.spd*dt*1.1, PY1+p.size, PY2-p.size);
  }

  // ── Right stick → optional manual aim override ──
  const rx = gp.axes[2], ry = gp.axes[3];
  if(Math.abs(rx)>dead||Math.abs(ry)>dead){
    // Right stick overrides auto-aim angle temporarily
    p.angle = Math.atan2(ry,rx)+Math.PI/2;
    gpAimOverride = true;
    if(shootCD<=0){ fireBullet(); shootCD=30; }
  } else {
    gpAimOverride = false;
  }

  // ── Bumpers / triggers → manual fire burst ──
  const fire = gp.buttons[5]?.pressed || gp.buttons[7]?.pressed ||  // RB / RT
               gp.buttons[0]?.pressed || gp.buttons[1]?.pressed;    // A / B (Xbox) / Cross / Circle
  if(fire && shootCD<=0){ fireBullet(); shootCD=30; }
}

function startGame(){
  lockLandscape();curLevel=0;score=0;pPowerups=[];pStats={dmg:1,spd:3.5,xif:0,tri:false};_lastInvKey='';
  hide('sTITLE');startMusic();
  // Show tutorial on first play, skip if seen
  if(!window._tutSeen){ window._tutSeen=true; tutGo(0); show('sTUT'); }
  else showLevelIntro();
}
let _tutPage=0;
const TUT_TOTAL=4;
function tutGo(n){
  document.querySelectorAll('.tut-page').forEach((p,i)=>p.classList.toggle('off',i!==n));
  document.querySelectorAll('.tut-dot').forEach((d,i)=>d.classList.toggle('active',i===n));
  _tutPage=n;
  document.getElementById('tutBack').style.opacity=n===0?'0.4':'1';
  document.getElementById('tutBack').style.pointerEvents=n===0?'none':'auto';
  document.getElementById('tutNext').querySelector('span').textContent=n===TUT_TOTAL-1?'BEGIN →':'NEXT →';
}
function tutNav(dir){
  const next=_tutPage+dir;
  if(next>=TUT_TOTAL){ hide('sTUT'); showLevelIntro(); return; }
  if(next<0) return;
  tutGo(next);
}

function showLevelIntro(){ const l=LEVELS[curLevel];document.getElementById('lTitle').textContent=l.name;document.getElementById('lSub').textContent=l.sub;document.getElementById('lTip').textContent=l.tip;show('sLEVEL'); }
function beginLevel(){ hide('sLEVEL');startLevel(); }
function startLevel(){
  const dun=genDungeon(curLevel);
  dungeonGrid=dun.grid;roomPos={...dun.start};
  visited=new Set([`${roomPos.x},${roomPos.y}`]);cleared=new Set([`${roomPos.x},${roomPos.y}`]);
  player={x:W/2,y:H/2,size:16,hp:10,maxHp:10,angle:0};
  enemies=[];eBullets=[];bullets=[];particles=[];drops=[];
  iframes=0;shootCD=0;gState='playing';roomBanner={text:'',sub:'',alpha:0,timer:0};_lastInvKey='';updateHUD();updateFireModeHUD();
  showMsg('— '+LEVELS[curLevel].floor+': '+LEVELS[curLevel].sub+' —',2600);
}
function triggerDeath(){
  gState='dead';
  const tips=['Your Secret Recovery Phrase is NEVER needed online. Etch it on steel. Lock it away. Never type it.','Ledger will never DM you on Discord, Twitter, Telegram, or Reddit. Every unsolicited contact is a scam.','Address poisoning is nearly invisible. One wrong character sends your funds to an attacker forever.','Dusted tokens are bait. Interact with them and your wallet identity is mapped — you become a target.','Phishing domains differ by one character. ledger.com is the only official site. Bookmark it. Trust nothing else.'];
  document.getElementById('dText').textContent=tips[Math.floor(Math.random()*tips.length)];
  document.getElementById('deathScore').textContent='SOULS COLLECTED: '+score.toLocaleString();
  show('sDEATH');
}
function triggerWin(){
  gState='win';
  document.getElementById('winScore').textContent='FINAL SCORE: '+score.toLocaleString();
  const ranks=[
    {min:0,     lbl:'APPRENTICE GUARDIAN'},
    {min:5000,  lbl:'VAULT DEFENDER'},
    {min:12000, lbl:'CIPHER KNIGHT'},
    {min:22000, lbl:'SEED PHRASE SENTINEL'},
    {min:35000, lbl:'LEDGER LEGEND'},
  ];
  const rank=ranks.slice().reverse().find(r=>score>=r.min)||ranks[0];
  document.getElementById('winRank').textContent='RANK: '+rank.lbl;
  show('sWIN');
}
function restartGame(goTitle=false){
  hide('sDEATH');hide('sWIN');
  curLevel=0;score=0;pPowerups=[];pStats={dmg:1,spd:3.5,xif:0,tri:false};_lastInvKey='';
  if(goTitle){stopMusic();show('sTITLE');}
  else showLevelIntro();
}

// ── INPUT ─────────────────────────────────────────────────────
document.addEventListener('keydown',e=>{
  pressed[e.key]=true;
  if(e.key===' '){pressed['_shoot']=true;e.preventDefault();}
  if(e.key==='f'||e.key==='F'){autoFire=!autoFire;updateFireModeHUD();showMsg(autoFire?'AUTO-FIRE ON':'MANUAL FIRE — HOLD SPACE',2000);}
  if(e.key==='Escape'||e.key==='p'||e.key==='P'){if(gState==='playing'||gState==='paused')togglePause();}
  if(e.key==='e'||e.key==='E'){
    pressed['e']=true;
    if(!e.repeat){ // prevent firing repeatedly while key held
      const rm=curRoom();
      if(rm&&rm.type==='shop'&&shopNearIdx>=0&&gState==='playing'&&shopEntryCooldown<=0){
        const item=rm.shopItems[shopNearIdx];
        if(item){
          if(score>=item.cost){
            score-=item.cost;applyPU(item,'shop');rm.shopItems.splice(shopNearIdx,1);
            updateHUD();flashPU(item);showMsg('⚗ ACQUIRED: '+item.nm,2200);shopNearIdx=-1;
          } else {
            showMsg('NOT ENOUGH SOULS — need '+item.cost+' pts',2000);
          }
        }
      }
    }
  }
});
document.addEventListener('keyup',e=>{ pressed[e.key]=false;if(e.key===' ')pressed['_shoot']=false;if(e.key==='e'||e.key==='E')pressed['e']=false; });
CV.addEventListener('mousedown',e=>{
  if(e.button!==0) return;
  if(gState==='playing'){
    // Check if clicking a shop pedestal
    const rm=curRoom();
    if(rm&&rm.type==='shop'){
      // Use shopNearIdx (where player is standing) not mouse click position
      if(shopNearIdx>=0&&rm.shopItems[shopNearIdx]&&shopEntryCooldown<=0){
        const item=rm.shopItems[shopNearIdx];
        if(score>=item.cost){
          score-=item.cost;applyPU(item,'shop');rm.shopItems.splice(shopNearIdx,1);
          updateHUD();flashPU(item);showMsg('⚗ ACQUIRED: '+item.nm,2200);shopNearIdx=-1;
        } else {
          showMsg('NOT ENOUGH SOULS — need '+item.cost+' pts',2000);
        }
        return;
      }
    }
    fireBullet();shootCD=30;
  }
});
CV.addEventListener('contextmenu',e=>e.preventDefault());

// ── BOOT ──────────────────────────────────────────────────────
// ── RESPONSIVE SCALING ───────────────────────────────────────
function scaleWrap(){
  const vw=window.innerWidth, vh=window.innerHeight;
  const outer=document.getElementById('outer');
  const scale=Math.min(vw/900, vh/660);
  outer.style.transform='';
  outer.style.zoom=scale;
  outer.style.position='absolute';
  outer.style.top=Math.round((vh-660*scale)/2)+'px';
  outer.style.left=Math.round((vw-900*scale)/2)+'px';
}

// Ask the browser to lock orientation to landscape
// This works in Chrome on Android — phone rotates automatically and stays there
function lockLandscape(){
  try{
    const s=screen.orientation||screen.msOrientation||screen.mozOrientation;
    if(s&&s.lock) s.lock('landscape').catch(()=>{});
    else if(screen.lockOrientation) screen.lockOrientation('landscape');
    else if(screen.mozLockOrientation) screen.mozLockOrientation('landscape');
  }catch(e){}
}

scaleWrap();
lockLandscape();
window.addEventListener('resize',()=>{scaleWrap();lockLandscape();});
window.addEventListener('orientationchange',()=>setTimeout(scaleWrap,200));

// ── TOUCH DETECTION & VIRTUAL JOYSTICK ───────────────────────
const isTouchDevice=()=>('ontouchstart' in window)||navigator.maxTouchPoints>0;

if(isTouchDevice()){
  document.getElementById('touch-controls').style.display='block';
  document.getElementById('cur').style.display='none';
  document.body.style.cursor='auto';
}

// Joystick state
const joy={active:false,startX:0,startY:0,dx:0,dy:0};
const JOY_MAX=40; // max displacement px (in wrap-scaled coords)

function getWrapCoords(touch){
  const wrap=document.getElementById('wrap');
  const r=wrap.getBoundingClientRect();
  return{
    x:(touch.clientX-r.left)*(900/r.width),
    y:(touch.clientY-r.top)*(660/r.height)
  };
}

const joyZone=document.getElementById('joy-zone');
const joyDot=document.getElementById('joy-dot');
const joyRing=document.getElementById('joy-ring');

joyZone.addEventListener('touchstart',e=>{
  e.preventDefault();
  const t=e.changedTouches[0];
  joy.active=true;
  // Position ring at touch point within joy-zone
  const zr=joyZone.getBoundingClientRect();
  const rx=t.clientX-zr.left, ry=t.clientY-zr.top;
  joyRing.style.left=rx+'px'; joyRing.style.bottom='';
  joyRing.style.top=ry+'px'; joyRing.style.transform='translate(-50%,-50%)';
  joy.startX=rx; joy.startY=ry;
  joy.dx=0; joy.dy=0;
},{passive:false});

joyZone.addEventListener('touchmove',e=>{
  e.preventDefault();
  if(!joy.active)return;
  const t=e.changedTouches[0];
  const zr=joyZone.getBoundingClientRect();
  const rx=t.clientX-zr.left, ry=t.clientY-zr.top;
  let ddx=rx-joy.startX, ddy=ry-joy.startY;
  const dist=Math.hypot(ddx,ddy);
  if(dist>JOY_MAX){ddx=ddx/dist*JOY_MAX;ddy=ddy/dist*JOY_MAX;}
  joy.dx=ddx/JOY_MAX; joy.dy=ddy/JOY_MAX;
  // Move dot
  joyDot.style.left=(50+ddx/JOY_MAX*38)+'%';
  joyDot.style.top=(50+ddy/JOY_MAX*38)+'%';
},{passive:false});

function resetJoy(){
  joy.active=false; joy.dx=0; joy.dy=0;
  joyDot.style.left='50%'; joyDot.style.top='50%';
}
joyZone.addEventListener('touchend',resetJoy,{passive:true});
joyZone.addEventListener('touchcancel',resetJoy,{passive:true});

// Shoot button
const shootBtn=document.getElementById('shoot-btn');
shootBtn.addEventListener('touchstart',e=>{
  e.preventDefault();
  if(gState==='playing'){fireBullet();shootCD=30;}
},{passive:false});

// E-buy button
const ebuyBtn=document.getElementById('ebuy-btn');
ebuyBtn.addEventListener('touchstart',e=>{
  e.preventDefault();
  pressed['e']=true;
  // Trigger shop purchase
  const rm=curRoom();
  if(rm&&rm.type==='shop'&&shopNearIdx>=0&&gState==='playing'){
    const item=rm.shopItems[shopNearIdx];
    if(item){
      if(score>=item.cost){
        score-=item.cost;applyPU(item);rm.shopItems.splice(shopNearIdx,1);
        updateHUD();showMsg('⚗ ACQUIRED: '+item.nm,2200);shopNearIdx=-1;
      } else {
        showMsg('NOT ENOUGH SOULS — need '+item.cost+' pts',2000);
      }
    }
  }
},{passive:false});
ebuyBtn.addEventListener('touchend',()=>pressed['e']=false,{passive:true});

// Show/hide E button based on shopNearIdx (called from drawRoomDeco)
function updateEBuyBtn(){
  const btn=document.getElementById('ebuy-btn');
  if(shopNearIdx>=0&&curRoom()&&curRoom().type==='shop'){
    btn.classList.add('vis');
  } else {
    btn.classList.remove('vis');
  }
}

// ── INJECT TOUCH MOVEMENT INTO update() ──────────────────────
// Patch the movement input to also read joystick
// We do this by wrapping the pressed[] reads with joy.dx/dy
const _origUpdate=update;

requestAnimationFrame(ts=>{lastTS=ts;requestAnimationFrame(loop);});
renderCharPreviews();
</script>
</body>
</html>
