<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>LEDGER DEFENDER</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Creepster&family=Special+Elite&family=Share+Tech+Mono&display=swap');

:root {
  --blood:    #8B0000;
  --blood2:   #C41E1E;
  --gold:     #B8860B;
  --gold2:    #DAA520;
  --rust:     #7A3B0A;
  --rot:      #2A1A0A;
  --black:    #05050A;
  --dark:     #0A080F;
  --dark2:    #100C18;
  --wall:     #0D0B16;
  --stone:    #161220;
  --mold:     #0A120A;
  --fog:      #1A1525;
  --text:     #C8BFA8;
  --dim:      #5A4F3A;
  --green:    #1A8A3A;
  --pus:      #4A6A1A;
}

*{margin:0;padding:0;box-sizing:border-box;}

html,body{
  width:100%;height:100%;
  background:#000;
  overflow:hidden;
  user-select:none;
  -webkit-user-select:none;
  touch-action:none;
  font-family:'Special Elite',cursive;
  margin:0;padding:0;
}

/* Grain overlay */
body::before{
  content:'';
  position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
  pointer-events:none;
  z-index:9999;
  opacity:.4;
}

body::after{
  content:'';
  position:fixed;inset:0;
  background:radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,.35) 100%);
  pointer-events:none;
  z-index:9998;
}

/* Outer container fills the entire viewport */
#outer{
  position:absolute;
  top:0;left:0;
  width:900px;
  height:660px;
  background:var(--black);
  overflow:hidden;
}

/* Game wrap: always 900×660 logical pixels, scaled by JS */
#wrap{
  position:relative;
  width:900px;
  height:660px;
  overflow:hidden;
  touch-action:none;
}

canvas{display:block;width:900px;height:660px;image-rendering:pixelated;}

/* Hide desktop cursor on mobile */
@media(pointer:coarse){
  #cur{ display:none !important; }
}

#cur{
  position:fixed;pointer-events:none;z-index:10000;
  transform:translate(-50%,-50%);width:24px;height:24px;mix-blend-mode:screen;
  opacity:0;transition:opacity .3s;
}

#hud{
  position:absolute;top:0;left:0;right:0;
  display:flex;justify-content:space-between;align-items:flex-start;
  padding:8px 10px 0;pointer-events:none;z-index:20;
  background:linear-gradient(to bottom,rgba(2,1,8,.97) 0%,rgba(2,1,8,.7) 70%,transparent 100%);
}

.hb{display:flex;flex-direction:column;gap:3px;}
.hl{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:.18em;color:#B8A878;text-transform:uppercase;}
.hv{font-family:'Creepster',cursive;font-size:22px;color:#FFD060;letter-spacing:.05em;text-shadow:0 0 12px rgba(184,134,11,.9),0 0 2px rgba(0,0,0,.8);}

#hpWrap{width:180px;height:10px;background:#0A0508;border:1px solid #2A1520;position:relative;overflow:hidden;}
#hpFill{height:100%;background:linear-gradient(to right,var(--blood),var(--blood2));transition:width .2s;position:relative;}
#hpFill::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:rgba(255,100,100,.4);}

#puSlots{display:flex;gap:4px;margin-top:2px;}
.pu-s{width:40px;height:46px;border:1px solid #2A1820;background:#08060E;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:16px;border-radius:3px;gap:2px;position:relative;}
.pu-s.lit{border-color:var(--gold);box-shadow:0 0 8px rgba(184,134,11,.6);}
.pu-s .pu-lbl{font-family:'Share Tech Mono',monospace;font-size:6px;color:var(--dim);letter-spacing:.05em;text-align:center;line-height:1.2;max-width:38px;overflow:hidden;}
.pu-s.lit .pu-lbl{color:var(--gold2);}

#mmcv{position:absolute;bottom:6px;right:6px;width:180px;height:150px;border:1px solid #3A1020;background:rgba(4,2,8,.97);z-index:20;pointer-events:none;box-shadow:0 0 20px rgba(139,0,0,.25),0 0 40px rgba(0,0,0,.9);border-radius:2px;transition:opacity .3s;}

#msg{position:absolute;bottom:52px;left:50%;transform:translateX(-50%);font-family:'Special Elite',cursive;font-size:13px;letter-spacing:.12em;color:var(--blood2);text-shadow:0 0 10px var(--blood);pointer-events:none;z-index:25;opacity:0;transition:opacity .4s;white-space:nowrap;text-align:center;}

.scr{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:30;padding:16px 20px;background:radial-gradient(ellipse at center, #100818 0%, #050508 100%);overflow-y:auto;-webkit-overflow-scrolling:touch;}
.scr::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(139,0,0,.015) 2px, rgba(139,0,0,.015) 4px);pointer-events:none;}
.scr.off{display:none;}

.st{font-family:'Creepster',cursive;font-size:56px;color:var(--blood2);text-shadow:0 0 20px var(--blood),0 0 40px rgba(139,0,0,.5),3px 3px 0 #000;letter-spacing:.06em;text-align:center;margin-bottom:2px;animation:flicker 4s infinite;}
@keyframes flicker{0%,95%,100%{opacity:1;}96%{opacity:.7;}97%{opacity:1;}98%{opacity:.4;}99%{opacity:1;}}

.ss{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--dim);letter-spacing:.3em;margin-bottom:18px;text-align:center;}
.tip{background:rgba(8,4,12,.9);border:1px solid #2A1020;border-left:3px solid var(--blood);padding:12px 16px;max-width:560px;width:100%;margin-bottom:18px;font-size:12px;line-height:1.85;color:var(--text);position:relative;}
.tip::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:repeating-linear-gradient(90deg,transparent,transparent 3px,rgba(139,0,0,.02) 3px,rgba(139,0,0,.02) 4px);pointer-events:none;}
.tlbl{font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:.22em;color:var(--blood2);margin-bottom:5px;text-transform:uppercase;}

.btn{font-family:'Creepster',cursive;font-size:18px;letter-spacing:.15em;padding:10px 34px;background:transparent;border:1px solid var(--blood);color:var(--blood2);cursor:pointer;transition:all .18s;text-shadow:0 0 8px var(--blood)80;position:relative;overflow:hidden;}
.btn::before{content:'';position:absolute;inset:0;background:var(--blood);transform:scaleX(0);transform-origin:left;transition:transform .18s;}
.btn:hover::before{transform:scaleX(1);}
.btn:hover{color:#fff;text-shadow:none;}
.btn span{position:relative;z-index:1;}

.ctrl{margin-top:14px;font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--dim);letter-spacing:.1em;line-height:2.2;text-align:center;}

#puChoices{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;justify-content:center;}
.pu-card{background:rgba(8,4,12,.95);border:1px solid #2A1020;border-top:2px solid var(--blood);padding:14px 12px;width:150px;cursor:pointer;transition:all .18s;text-align:center;}
.pu-card:hover{background:rgba(139,0,0,.12);border-color:var(--blood2);}
.pu-ico{font-size:30px;margin-bottom:7px;}
.pu-nm{font-family:'Creepster',cursive;font-size:13px;letter-spacing:.08em;color:var(--gold2);margin-bottom:5px;}
.pu-dc{font-size:10px;color:var(--text);line-height:1.6;}

#shopPrompt{position:absolute;bottom:70px;left:50%;transform:translateX(-50%);font-family:'Creepster',cursive;font-size:18px;color:#FFD060;letter-spacing:.1em;text-shadow:0 0 12px #B8860B,0 0 24px rgba(184,134,11,.6);pointer-events:none;z-index:22;opacity:0;transition:opacity .25s;white-space:nowrap;text-align:center;}

#puPop{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:50;opacity:0;transition:opacity .5s;text-align:center;background:rgba(5,3,10,.97);border:2px solid var(--gold);padding:24px 32px;max-width:340px;min-width:260px;}
#puPop .pi{font-size:52px;display:block;margin-bottom:6px;}
#puPop .pn{font-family:'Creepster',cursive;font-size:22px;color:var(--gold2);letter-spacing:.08em;margin-bottom:6px;}
#puPop .pg{font-family:'Share Tech Mono',monospace;font-size:13px;color:#66FF88;margin-bottom:8px;letter-spacing:.05em;}
#puPop .pd{font-size:10px;color:var(--text);line-height:1.7;opacity:.8;}
#puPop .tacq{font-family:'Creepster',cursive;font-size:11px;color:var(--blood2);letter-spacing:.2em;margin-bottom:10px;}

/* ── CHARACTER SELECT ── */
.char-label{
  font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:.3em;
  color:var(--dim);margin-bottom:8px;text-align:center;
}
#schar-wrap{
  display:flex;gap:16px;margin-bottom:12px;
}
.char-opt{
  width:160px;
  padding:8px 8px 10px;
  background:rgba(8,4,12,.95);
  border:2px solid #2A1020;
  cursor:pointer;
  transition:border-color .15s, background .15s, box-shadow .15s;
  text-align:center;
  position:relative;
  overflow:hidden;
  display:flex;
  flex-direction:row;
  align-items:center;
  gap:10px;
}
.char-opt:hover{ border-color:#6A2030; background:rgba(80,0,20,.2); }
.char-opt.picked{
  border-color:var(--blood2);
  background:rgba(100,0,0,.28);
  box-shadow:0 0 20px rgba(196,30,30,.55), inset 0 0 14px rgba(139,0,0,.35);
}
.char-preview-wrap{
  flex-shrink:0;
  width:52px; height:68px;
  position:relative;
  overflow:hidden;
}
.char-canvas{
  display:block;
  width:52px; height:68px;
  image-rendering:pixelated;
}
.char-info{ flex:1; text-align:left; }
.char-nm{
  font-family:'Creepster',cursive;font-size:16px;
  color:var(--gold2);letter-spacing:.06em;
  margin-bottom:2px;line-height:1;
}
.char-sub{font-size:9px;color:var(--dim);line-height:1.5;}
.char-sel-ring{
  font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:.1em;
  color:var(--blood2);text-shadow:0 0 6px var(--blood);
  margin-top:5px;transition:opacity .2s;
}


/* ── TOUCH CONTROLS ── */
#touch-controls{
  display:none; /* shown via JS on touch devices */
  position:absolute; inset:0;
  pointer-events:none;
  z-index:40;
}
#joy-zone{
  position:absolute;
  left:0; bottom:0;
  width:48%; height:44%;
  pointer-events:auto;
}
#joy-ring{
  position:absolute;
  left:50%; bottom:30%;
  transform:translate(-50%,50%);
  width:100px; height:100px;
  border-radius:50%;
  border:2px solid rgba(139,0,0,.5);
  background:rgba(5,3,10,.5);
  pointer-events:none;
}
#joy-dot{
  position:absolute;
  width:38px; height:38px;
  border-radius:50%;
  background:rgba(196,30,30,.7);
  border:2px solid rgba(255,80,80,.6);
  box-shadow:0 0 12px rgba(139,0,0,.6);
  transform:translate(-50%,-50%);
  top:50%; left:50%;
  pointer-events:none;
  transition:none;
}
#shoot-btn{
  position:absolute;
  right:6%; bottom:22%;
  width:80px; height:80px;
  border-radius:50%;
  background:rgba(139,0,0,.55);
  border:2px solid rgba(196,30,30,.8);
  box-shadow:0 0 18px rgba(139,0,0,.5);
  pointer-events:auto;
  display:flex; align-items:center; justify-content:center;
  font-family:'Creepster',cursive;
  font-size:11px; letter-spacing:.1em;
  color:rgba(255,150,150,.9);
  user-select:none;
  -webkit-tap-highlight-color:transparent;
  text-align:center; line-height:1.3;
}
#shoot-btn:active{ background:rgba(200,30,30,.7); transform:scale(.93); }
#ebuy-btn{
  position:absolute;
  right:6%; bottom:48%;
  width:68px; height:68px;
  border-radius:50%;
  background:rgba(184,134,11,.55);
  border:2px solid #DAA520;
  box-shadow:0 0 14px rgba(184,134,11,.5);
  pointer-events:auto;
  display:none;
  align-items:center; justify-content:center;
  font-family:'Creepster',cursive;
  font-size:12px; color:#FFD060;
  user-select:none;
  -webkit-tap-highlight-color:transparent;
  text-align:center;
}
#ebuy-btn.vis{ display:flex; }
#ebuy-btn:active{ background:rgba(218,165,32,.7); transform:scale(.93); }
/* Joystick direction labels */
.joy-arrow{
  position:absolute; font-size:13px; color:rgba(139,0,0,.4);
  pointer-events:none; line-height:1;
}

.tut-page{width:100%;}
.tut-page.off{display:none;}
.tut-dot{width:10px;height:10px;border-radius:50%;border:1px solid var(--blood);background:transparent;cursor:pointer;transition:background .2s;}
.tut-dot.active{background:var(--blood2);}

#invPanel{
  position:absolute;
  bottom:162px;right:6px;
  width:180px;
  pointer-events:none;
  z-index:21;
  background:rgba(4,2,8,.82);
  border:1px solid rgba(184,134,11,.35);
  border-radius:3px;
  padding:5px 6px;
  transition:opacity .3s;
}
#invSlots{
  display:flex;
  flex-direction:column;
  gap:4px;
}
.inv-item{
  display:flex;
  align-items:center;
  gap:6px;
  background:rgba(20,14,30,.9);
  border:1px solid var(--gold);
  border-radius:3px;
  padding:4px 6px;
  animation:invFadeIn .4s ease;
}
.inv-icon{font-size:16px;flex-shrink:0;}
.inv-text{display:flex;flex-direction:column;gap:2px;}
.inv-name{font-family:'Creepster',cursive;font-size:11px;color:var(--gold2);letter-spacing:.05em;line-height:1;}
.inv-eff{font-family:'Share Tech Mono',monospace;font-size:8px;color:#66FF88;line-height:1.2;}
.inv-empty{
  font-family:'Share Tech Mono',monospace;font-size:8px;
  color:var(--dim);letter-spacing:.1em;padding:2px 4px;
  text-align:center;
}
@keyframes invFadeIn{from{opacity:0;transform:translateX(8px)}to{opacity:1;transform:translateX(0)}}

#pauseBtn{
  margin-top:6px;
  padding:5px 14px;
  font-family:'Creepster',cursive;
  font-size:14px;
  letter-spacing:.12em;
  background:rgba(139,0,0,.4);
  border:1px solid var(--blood2);
  color:var(--blood2);
  cursor:pointer;
  border-radius:3px;
  pointer-events:auto;
  transition:all .15s;
  text-shadow:0 0 8px var(--blood);
  box-shadow:0 0 8px rgba(139,0,0,.3);
}
#pauseBtn:hover{
  background:rgba(196,30,30,.6);
  border-color:#FF4444;
  color:#FF8888;
  box-shadow:0 0 14px rgba(139,0,0,.6);
}
#pauseBtn:active{
  transform:scale(.95);
}
</style>
</head>
<body>

<svg id="cur" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
  <circle cx="12" cy="12" r="9" fill="none" stroke="#8B0000" stroke-width="1.5" opacity=".8"/>
  <circle cx="12" cy="12" r="2.5" fill="#C41E1E"/>
  <line x1="12" y1="1" x2="12" y2="6" stroke="#8B0000" stroke-width="1.5"/>
  <line x1="12" y1="18" x2="12" y2="23" stroke="#8B0000" stroke-width="1.5"/>
  <line x1="1" y1="12" x2="6" y2="12" stroke="#8B0000" stroke-width="1.5"/>
  <line x1="18" y1="12" x2="23" y2="12" stroke="#8B0000" stroke-width="1.5"/>
</svg>

<div id="outer">
<div id="wrap">
<canvas id="cv" width="900" height="660"></canvas>

<div id="hud">
  <div class="hb">
    <div style="font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:.18em;color:#FF9999;text-transform:uppercase;">INTEGRITY</div>
    <div id="hpWrap"><div id="hpFill" style="width:100%"></div></div>

  </div>
  <div class="hb" style="align-items:center">
    <div class="hl">Floor</div>
    <div class="hv" id="floorD">B1</div>
    <div class="hl" style="margin-top:2px">Danger</div>
    <div class="hv" id="diffD" style="font-size:10px;color:#C41E1E">NOVICE</div>
    <div style="margin-top:4px;width:90px;height:5px;background:#1A0810;border:1px solid #2A1020;border-radius:2px;overflow:hidden">
      <div id="progFill" style="height:100%;width:20%;background:linear-gradient(to right,#8B0000,#CC2200);transition:width .5s;border-radius:2px"></div>
    </div>
    <div class="hl" style="margin-top:2px" id="progLbl">FLOOR 1 OF 5</div>
    <button id="fireModeBtn" onclick="autoFire=!autoFire;updateFireModeHUD();" style="margin-top:4px;padding:2px 7px;font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:.08em;background:rgba(139,0,0,.25);border:1px solid #5A1818;color:#AA4444;cursor:pointer;border-radius:2px;pointer-events:auto;">AUTO-FIRE: ON</button>
    <div style="font-size:7px;color:#443333;font-family:'Share Tech Mono',monospace;margin-top:1px;">F to toggle</div>
  </div>
  <div class="hb" style="align-items:flex-end">
    <div style="font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:.18em;color:#FF9999;text-transform:uppercase;">SOULS CLEANSED</div>
    <div class="hv" id="scoreD">0</div>
    <button id="pauseBtn" onclick="togglePause()">⏸ PAUSE</button>
  </div>
</div>

<!-- INVENTORY PANEL -->
<div id="invPanel">
  <div class="hl" style="letter-spacing:.2em;margin-bottom:4px">DEFENSES</div>
  <div id="invSlots"></div>
</div>

<canvas id="mmcv" width="180" height="150"></canvas>
<div id="msg"></div>
<div id="shopPrompt"></div>

<div id="puPop">
  <div class="tacq">⚗ ACQUIRED</div>
  <span class="pi" id="puPopI"></span>
  <div class="pn" id="puPopN"></div>
  <div class="pg" id="puPopG"></div>
  <div class="pd" id="puPopD"></div>
</div>

<!-- TITLE -->
<div class="scr" id="sTITLE">
  <div class="st" style="font-size:40px;margin-bottom:2px;line-height:1">LEDGER DEFENDER</div>
  <div class="ss" style="margin-bottom:12px;font-size:9px">▸ PROTECT YOUR SECRET RECOVERY PHRASE ◂</div>
  <div class="char-label">— CHOOSE YOUR VESSEL —</div>
  <div id="schar-wrap">

    <div class="char-opt picked" id="copt-boy" onclick="pickChar('boy')">
      <div class="char-preview-wrap">
        <canvas class="char-canvas" id="previewBoy" width="52" height="68"></canvas>
      </div>
      <div class="char-info">
        <div class="char-nm">THE BOY</div>
        <div class="char-sub">Button-eyed<br>haunted vessel</div>
        <div class="char-sel-ring" id="ring-boy">◈ SELECTED ◈</div>
      </div>
    </div>

    <div class="char-opt" id="copt-girl" onclick="pickChar('girl')">
      <div class="char-preview-wrap">
        <canvas class="char-canvas" id="previewGirl" width="52" height="68"></canvas>
      </div>
      <div class="char-info">
        <div class="char-nm">THE GIRL</div>
        <div class="char-sub">Porcelain face<br>cracked and cold</div>
        <div class="char-sel-ring" id="ring-girl" style="opacity:0">◈ SELECTED ◈</div>
      </div>
    </div>

  </div>
  <button class="btn" onclick="startGame()"><span>▶ DESCEND INTO THE DUNGEON</span></button>
  <div class="tip" style="max-width:380px;margin-top:12px;margin-bottom:0;font-size:11px;line-height:1.7">
    <div class="tlbl">Controls</div>
    WASD / Arrow Keys — Move &nbsp;·&nbsp; <em>Auto-aims at enemies</em><br>
    Auto-fire ON by default · Press <strong>F</strong> or tap the HUD button to switch to manual (hold SPACE)<br>
    Gamepad: Left stick moves · Right stick aims · RT fires<br>
    Walk through open doors · Stand on relics · Press E at shop
  </div>
</div>

<!-- TUTORIAL -->
<div class="scr off" id="sTUT">
  <div class="st" style="font-size:32px;margin-bottom:4px">HOW TO SURVIVE</div>
  <div class="ss" style="margin-bottom:14px">READ THIS — YOUR WALLET DEPENDS ON IT</div>
  <div id="tutPages">

    <!-- Page 1: Movement & Shooting -->
    <div class="tut-page" id="tut-0">
      <div class="tip" style="max-width:540px;font-size:13px;line-height:1.9">
        <div class="tlbl">Your Weapon</div>
        You are a Ledger hardware wallet fighting through a dungeon of scammers.<br><br>
        <strong style="color:var(--gold2)">Move</strong> with WASD or Arrow Keys<br>
        <strong style="color:var(--gold2)">Your doll auto-rotates</strong> to face the nearest enemy<br>
        <strong style="color:var(--gold2)">AUTO-FIRE mode</strong> — your doll fires automatically (default)<br>
        <strong style="color:var(--gold2)">MANUAL mode</strong> — hold SPACE or click to fire, press <strong>F</strong> to switch<br>
        <strong style="color:var(--gold2)">DODGE enemy bullets</strong> — they get faster every floor
      </div>
    </div>

    <!-- Page 2: The Enemies -->
    <div class="tut-page off" id="tut-1">
      <div class="tip" style="max-width:540px;font-size:13px;line-height:1.9">
        <div class="tlbl">Know Your Enemies</div>
        Each enemy represents a <strong style="color:var(--blood2)">real crypto scam</strong> targeting Ledger users:<br><br>
        <span style="color:#CC1111">✉ PHISH MAIL</span> — Fake Ledger emails stealing your Secret Recovery Phrase<br>
        <span style="color:#AA2200">📜 SCAM LETTER</span> — Postal letters claiming your device needs "verification"<br>
        <span style="color:#551188">🎧 FAKE AGENT</span> — Imposters on Discord/Twitter offering fake support<br>
        <span style="color:#883300">😈 TRUST SCAM</span> — Social engineers building fake trust before striking<br>
        <span style="color:#006644">💻 FAKE ADDRESS</span> — Lookalike wallet addresses in your history<br>
        <span style="color:#115533">🪙 WALLET DUST</span> — Tiny tokens sent to track and deanonymize your wallet
      </div>
    </div>

    <!-- Page 3: The Dungeon -->
    <div class="tut-page off" id="tut-2">
      <div class="tip" style="max-width:540px;font-size:13px;line-height:1.9">
        <div class="tlbl">The Dungeon</div>
        Each floor is a maze of rooms. Clear all enemies to unlock doors.<br><br>
        <strong style="color:var(--gold2)">Walk into open doorways</strong> to move between rooms<br>
        <strong style="color:#55AAFF">★ RELIC rooms</strong> — step on 💎 to choose a security upgrade<br>
        <strong style="color:var(--gold2)">$ SHOP rooms</strong> — walk to a pedestal and press <strong>E</strong> to buy<br>
        <strong style="color:#FF5555">B BOSS rooms</strong> — defeat the boss to advance to the next floor<br><br>
        There are <strong style="color:var(--gold2)">5 floors</strong>. Each one is harder. Defeat The Architect to win.
      </div>
    </div>

    <!-- Page 4: The Golden Rule -->
    <div class="tut-page off" id="tut-3">
      <div class="tip" style="max-width:540px;font-size:14px;line-height:2">
        <div class="tlbl">The One Rule That Protects Everything</div>
        <div style="font-size:20px;color:var(--blood2);font-family:Creepster,cursive;letter-spacing:.05em;margin-bottom:10px">Your Secret Recovery Phrase is SACRED.</div>
        ✦ <strong>Never type it online</strong> — not even on ledger.com<br>
        ✦ <strong>Never share it</strong> — with anyone, ever, for any reason<br>
        ✦ <strong>Never photograph it</strong> — cameras and cloud sync are attack vectors<br>
        ✦ <strong>Store it on steel</strong> — paper burns, steel lasts forever<br><br>
        <span style="color:var(--gold2)">Ledger will NEVER ask for your 24 words. Anyone who does is a scammer.</span>
      </div>
    </div>

  </div>
  <div style="display:flex;gap:12px;align-items:center;margin-top:4px">
    <button class="btn" id="tutBack" onclick="tutNav(-1)" style="opacity:0.4;pointer-events:none"><span>← BACK</span></button>
    <div id="tutDots" style="display:flex;gap:6px">
      <div class="tut-dot active" onclick="tutGo(0)"></div>
      <div class="tut-dot" onclick="tutGo(1)"></div>
      <div class="tut-dot" onclick="tutGo(2)"></div>
      <div class="tut-dot" onclick="tutGo(3)"></div>
    </div>
    <button class="btn" id="tutNext" onclick="tutNav(1)"><span>NEXT →</span></button>
  </div>
</div>

<!-- LEVEL INTRO -->
<div class="scr off" id="sLEVEL">
  <div class="st" id="lTitle" style="font-size:40px"></div>
  <div class="ss" id="lSub"></div>
