<script>
'use strict';
const CV=document.getElementById('cv');
const CX=CV.getContext('2d');
const MM=document.getElementById('mmcv');
const MC=MM.getContext('2d');
const W=900,H=660;
const WT=52, DW=68, DHW=DW/2;
const PX1=WT,PX2=W-WT,PY1=WT,PY2=H-WT;
function _syncWH(){} // no-op, kept for compat

const CUR=document.getElementById('cur');
let mouse={x:W/2,y:H/2};
let _cursorTimeout;
document.addEventListener('mousemove',e=>{
  CUR.style.left=e.clientX+'px'; CUR.style.top=e.clientY+'px';
  CUR.style.opacity='1';
  clearTimeout(_cursorTimeout);
  _cursorTimeout=setTimeout(()=>CUR.style.opacity='0', 2000);
  const r=CV.getBoundingClientRect();
  mouse.x=(e.clientX-r.left)*(W/r.width);
  mouse.y=(e.clientY-r.top)*(H/r.height);
});

// ── STATE ─────────────────────────────────────────────────────
let gState='title';
let selectedChar='boy'; // 'boy' or 'girl'
let score=0,curLevel=0;
let player,enemies,bullets,eBullets,particles,drops;
let pressed={},shootCD=0,iframes=0,lastTS=0;
let autoFire=true; // toggle with F or tap the HUD button
let pPowerups=[],pStats={dmg:1,spd:3.5,xif:0,tri:false};
let dungeonGrid=[],roomPos={x:0,y:0};
let visited=new Set(),cleared=new Set();
let shopNearIdx=-1;
let shopEntryCooldown=0;
let _lastInvKey='';
let roomBanner={text:'',sub:'',alpha:0,timer:0};
const GW=6,GH=5;

// ── DATA ──────────────────────────────────────────────────────
// Difficulty multiplier per floor: enemy HP, speed, bullet speed, count
const FLOOR_DIFF=[
  {hpMult:1.0, spdMult:1.0, bsMult:1.0, cntBonus:0,  label:'NOVICE'},
  {hpMult:1.6, spdMult:1.2, bsMult:1.3, cntBonus:2,  label:'DANGEROUS'},
  {hpMult:2.5, spdMult:1.45,bsMult:1.6, cntBonus:4,  label:'LETHAL'},
  {hpMult:3.8, spdMult:1.7, bsMult:2.0, cntBonus:6,  label:'NIGHTMARE'},
  {hpMult:5.5, spdMult:2.0, bsMult:2.5, cntBonus:9,  label:'INFERNAL'},
];

const LEVELS=[
  {name:'FLOOR I',   sub:'THE PHISHING CATACOMBS',      floor:'B1',
   tip:'Phishing emails copy Ledger Wallet exactly to steal your Secret Recovery Phrase. They manufacture urgency. Ledger will NEVER ask for your 24 words.',
   pool:['phish_email','scam_letter'], boss:'boss_phisher'},
  {name:'FLOOR II',  sub:'THE FAKE SUPPORT LABYRINTH',  floor:'B2',
   tip:'Fake support agents haunt Discord, Reddit, and Telegram. They want your Secret Recovery Phrase. Real support is only at support.ledger.com.',
   pool:['fake_support','social_eng','phish_email'], boss:'boss_support'},
  {name:'FLOOR III', sub:'THE DUST & POISON DEPTHS',    floor:'B3',
   tip:'Dusting attacks map your wallet. Address poisoning plants lookalike addresses. Verify every character of every address — always.',
   pool:['addr_poison','dust_token','social_eng','scam_letter'], boss:'boss_dust'},
  {name:'FLOOR IV',  sub:'THE SYNDICATE STRONGHOLD',    floor:'B4',
   tip:'All factions converge. Phishers, fake agents and poisoners hunt in coordinated waves. Your Secret Recovery Phrase is the only thing they want.',
   pool:['phish_email','fake_support','addr_poison','dust_token','social_eng'], boss:'boss_syndicate'},
  {name:'FLOOR V',   sub:'THE FINAL VAULT',             floor:'B5',
   tip:'The mastermind awaits. Every scam type, maximum aggression. Defeat the Final Boss to seal your wallet forever. This is what all the training was for.',
   pool:['phish_email','fake_support','addr_poison','dust_token','social_eng','scam_letter'], boss:'boss_final'},
];

// Short scam-type description shown under each enemy
const SCAM_HINTS={
  phish_email:  'FAKE EMAIL',
  scam_letter:  'POSTAL SCAM',
  fake_support: 'FAKE SUPPORT',
  social_eng:   'TRUST SCAM',
  addr_poison:  'FAKE ADDRESS',
  dust_token:   'WALLET DUST',
};

const ET={
  phish_email: {lbl:'PHISH MAIL', col:'#CC1111',sz:18,hp:8,spd:1.6,sr:75, bs:3.0,pts:40, shp:'envelope',
    tip:'Phishing emails mimic Ledger Wallet to perfection. Bookmark ledger.com — never click emailed links.'},
  scam_letter: {lbl:'SCAM LETTER',col:'#AA2200',sz:17,hp:8,spd:1.4,sr:90, bs:2.8,pts:35,  shp:'letter',
    tip:'Postal scam letters are a real attack. Ledger never mails security verification requests.'},
  fake_support:{lbl:'FAKE AGENT', col:'#551188',sz:19,hp:10,spd:1.3,sr:65, bs:3.0,pts:55, shp:'agent',
    tip:'Fake support agents operate only through DMs. Real Ledger support never contacts you unsolicited.'},
  social_eng:  {lbl:'SOCIAL ENG', col:'#883300',sz:18,hp:8,spd:1.9,sr:70, bs:3.2,pts:45, shp:'charmer',
    tip:'Social engineers build trust for weeks before asking. Your Secret Recovery Phrase is for your eyes only — share it with no one.'},
  addr_poison: {lbl:'ADDR POISON',col:'#006644',sz:15,hp:6,spd:2.8,sr:90, bs:2.6,pts:30,  shp:'address',
    tip:'Address poisoning plants a near-identical address in your history. Verify every single character before every send.'},
  dust_token:  {lbl:'DUST TOKEN', col:'#115533',sz:13,hp:5,spd:3.0,sr:95, bs:2.4,pts:25,  shp:'dust',
    tip:'Dusted tokens track and deanonymize your wallet. Never swap, send, or approve unsolicited tokens.'},
  boss_phisher:{lbl:'PHISH LORD', col:'#FF1111',sz:44,hp:24,spd:.72,sr:52,bs:5.2,pts:1400,shp:'boss_env',  boss:true,
    tip:'Industrial phishing operations spoof Ledger Wallet entirely. Use bookmarks and run the Genuine Check on every device.'},
  boss_support:{lbl:'SCAM KING',  col:'#7700BB',sz:46,hp:30,spd:.62,sr:46,bs:4.5,pts:1700,shp:'boss_agent',boss:true,
    tip:'Full fake-support operations run real call centers. Only trust support.ledger.com. Your Secret Recovery Phrase is never needed.'},
  boss_dust:   {lbl:'DUST WITCH',   col:'#007755',sz:48,hp:34,spd:.58,sr:40, bs:5.5,pts:2000,shp:'boss_dust',     boss:true,
    tip:'Mass dusting and address poisoning work in tandem. Hardware verification and full address checks defeat both.'},
  boss_syndicate:{lbl:'SYNDICATE',  col:'#882266',sz:52,hp:45,spd:.52,sr:35, bs:5.8,pts:2800,shp:'boss_agent',   boss:true,
    tip:'The Syndicate coordinates all scam types simultaneously. No single defense stops them — you need layered security across every channel.'},
  boss_final:  {lbl:'THE ARCHITECT',col:'#CC6600',sz:58,hp:60,spd:.48,sr:28, bs:6.2,pts:4000,shp:'boss_env',    boss:true,
    tip:'The Architect built the entire scam network. Defeat them and your Secret Recovery Phrase is safe — but only if it is NEVER online.'},
};

const PUS=[
  {id:'steel',    ic:'🪨',nm:'Steel Tablet',    game:'Max health +2',desc:'Engrave your Secret Recovery Phrase on fireproof steel.',eff:'maxhp+2'},
  {id:'offline',  ic:'🔌',nm:'Offline Storage', game:'Move speed +15%',desc:'Cold storage means your keys never touch the internet.',eff:'spd+.5'},
  {id:'verify',   ic:'🔍',nm:'URL Verifier',    game:'Bullet damage +50%',desc:'Always confirm ledger.com — not lookalike domains.',eff:'dmg+.5'},
  {id:'genuine',  ic:'✅',nm:'Genuine Check',   game:'Restore +3 health now',desc:'Run the Genuine Check on every Ledger device before use.',eff:'hp+3'},
  {id:'passphrase',ic:'🔑',nm:'Passphrase Shield',game:'Longer invincibility after hits',desc:'The 25th-word passphrase is a hidden layer only you know.',eff:'shield'},
  {id:'2fa',      ic:'🛡️',nm:'Hardware 2FA',   game:'Much longer invincibility after hits',desc:'Hardware 2FA keys cannot be SIM-swapped.',eff:'iframes+25'},
  {id:'bookmark', ic:'📌',nm:'Bookmark Guard',  game:'Fire extra side bullets',desc:'Phishing lives in search ads — always bookmark ledger.com.',eff:'dmg+.5'},
  {id:'multisig', ic:'⚡',nm:'Multisig Vault',  game:'Triple shot — 3 bullets per fire',desc:'Multisig removes single points of failure.',eff:'tri'},
];

// ── DUNGEON GEN ───────────────────────────────────────────────
function genDungeon(li){
  const _li=li;
  const lvl=LEVELS[li];
  const grid=Array.from({length:GH},()=>Array(GW).fill(null));
  const start={x:1,y:2};
  grid[start.y][start.x]=makeRoom('start',start.x,start.y,lvl,li);
  let cx=start.x,cy=start.y;
  const placed=[{x:cx,y:cy}];
  const DIRS=[{dx:1,dy:0},{dx:-1,dy:0},{dx:0,dy:1},{dx:0,dy:-1}];
  for(let step=0;step<18;step++){
    const d=DIRS[Math.floor(Math.random()*4)];
    const nx=cx+d.dx,ny=cy+d.dy;
    if(nx>=0&&nx<GW&&ny>=0&&ny<GH){
      cx=nx;cy=ny;
      if(!grid[ny][nx]){
        let t='combat';
        if(placed.length===9)  t='boss';
        else if(placed.length===4||placed.length===12) t='powerup';
        else if(placed.length===3||placed.length===7||(placed.length===11&&li<2)) t='shop';
        grid[ny][nx]=makeRoom(t,nx,ny,lvl,li);
        placed.push({x:nx,y:ny});
      }
    }
  }
  if(!placed.some(p=>grid[p.y][p.x].type==='boss')){
    const last=placed[placed.length-1];
    grid[last.y][last.x]=makeRoom('boss',last.x,last.y,lvl,li);
  }
  placed.forEach(({x,y})=>{
    const rm=grid[y][x];
    DIRS.forEach(({dx,dy})=>{
      const nx=x+dx,ny=y+dy;
      if(nx>=0&&nx<GW&&ny>=0&&ny<GH&&grid[ny][nx]){
        if(dx===1)  rm.doors.R=true;
        if(dx===-1) rm.doors.L=true;
        if(dy===1)  rm.doors.D=true;
        if(dy===-1) rm.doors.U=true;
      }
    });
  });
  return {grid,start};
}

function makeRoom(type,gx,gy,lvl,li){
  return{type,gx,gy,
    cleared:type==='start'||type==='shop'||type==='powerup',
    wavesLeft:type==='combat'?2:type==='boss'?0:0,
    doors:{U:false,D:false,L:false,R:false},
    enemies:buildEnemies(type,lvl),
    obstacles:buildObs(type),
    drops:[],puPending:type==='powerup',
    shopItems:type==='shop'?buildShop():[],
    _flicker:Math.random()*1000,
    _seed:Math.random()*1000,
    theme:['dungeon','liminal','forest','candyland','void'][Math.min(li!==undefined?li:0,4)],
  };
}

function buildEnemies(type,lvl){
  if(type==='start'||type==='shop'||type==='powerup') return[];
  if(type==='boss'){
    const list=[mkE(lvl.boss,W/2,H*0.28)];
    const minionCount=1+Math.floor(curLevel/2);
    for(let i=0;i<minionCount;i++){
      const t=lvl.pool[Math.floor(Math.random()*lvl.pool.length)];
      let ex,ey;
      do{ex=PX1+80+Math.random()*(PX2-PX1-160);ey=PY1+80+Math.random()*(PY2-PY1-160);}
      while(Math.hypot(ex-W/2,ey-H/2)<180);
      list.push(mkE(t,ex,ey));
    }
    return list;
  }
  const d=FLOOR_DIFF[Math.min(curLevel,FLOOR_DIFF.length-1)];
  const base=3+d.cntBonus;
  const cnt=base+Math.floor(Math.random()*2);
  return Array.from({length:cnt},()=>{
    const t=lvl.pool[Math.floor(Math.random()*lvl.pool.length)];
    let ex,ey;
    do{ex=PX1+70+Math.random()*(PX2-PX1-140);ey=PY1+70+Math.random()*(PY2-PY1-140);}
    while(Math.hypot(ex-W/2,ey-H/2)<160);
    return mkE(t,ex,ey);
  });
}

function mkE(type,x,y){
  const c=ET[type];
  const d=FLOOR_DIFF[Math.min(curLevel,FLOOR_DIFF.length-1)];
  const hp=Math.ceil((c.hp+curLevel)*d.hpMult);
  const maxHp=hp;
  return{type,x,y,vx:0,vy:0,
    ...c,                          // base stats first
    hp,maxHp,                      // calculated HP overwrites c.hp
    stimer:Math.random()*c.sr,phase:Math.random()*Math.PI*2,_flash:0,
    spd:c.spd*d.spdMult,
    bs:c.bs*d.bsMult,
    sz:c.sz+(Math.random()*3-1.5)};
}

function buildObs(type){
  if(type==='start') return[];
  const n=2+Math.floor(Math.random()*5);
  return Array.from({length:n},()=>({
    x:PX1+80+Math.random()*(PX2-PX1-160),y:PY1+80+Math.random()*(PY2-PY1-160),
    w:28+Math.random()*50,h:22+Math.random()*40,
    kind:Math.random()<.6?'crypt':'pillar',_r:Math.random(),
  }));
}

function buildShop(){
  return PUS.slice().sort(()=>Math.random()-.5).slice(0,3)
    .map((p,i)=>({...p,cost:shopCostForFloor(),slot:i}));
}
function shopCostForFloor(){
  const base=[150,220,400,600,900][Math.min(curLevel,4)];
  return base+Math.floor(Math.random()*(base*.6));
}

// ── HELPERS ───────────────────────────────────────────────────
function curRoom(){ return dungeonGrid[roomPos.y]?.[roomPos.x]; }
function show(id){ document.getElementById(id).classList.remove('off'); }
function hide(id){ document.getElementById(id).classList.add('off'); }
function clamp(v,lo,hi){ return Math.max(lo,Math.min(hi,v)); }
function outBounds(b){ return b.x<WT-14||b.x>W-WT+14||b.y<WT-14||b.y>H-WT+14; }
function darken(hex,f){
  const n=parseInt(hex.replace('#',''),16);
  return `rgb(${Math.max(0,((n>>16)&255)*f)|0},${Math.max(0,((n>>8)&255)*f)|0},${Math.max(0,(n&255)*f)|0})`;
}
function showMsg(txt,dur=2200){
  const el=document.getElementById('msg');
  el.textContent=txt;el.style.opacity=1;
  clearTimeout(el._t);el._t=setTimeout(()=>el.style.opacity=0,dur);
}

// ── DRAWING ───────────────────────────────────────────────────
function drawScene(){
  const rm=curRoom();if(!rm)return;
  drawFloor(rm);drawObs(rm.obstacles);drawRoomDeco(rm);drawWalls(rm);
  drops.forEach(drawDrop);particles.forEach(drawParticle);
  enemies.forEach(drawEnemy);eBullets.forEach(drawBullet);bullets.forEach(drawBullet);
  if(player)drawPlayer(player);
  drawRoomBanner();
  drawMM();
  fadeHUDPanels();
}

function drawFloor(rm){
  const t=Date.now()/1000;
  const theme=rm.theme||'dungeon';
  const seed=rm._seed||0;

  if(theme==='dungeon'){
    // ── CRYPT FLOOR — clearly lighter than walls ──────────────
    // Stone floor — noticeably lighter/warmer than the dark wall band
    CX.fillStyle='#221A35';CX.fillRect(0,0,W,H);
    const ts=46;
    for(let tx=0;tx<W;tx+=ts)for(let ty=0;ty<H;ty+=ts){
      const v=(tx/ts+ty/ts)%2===0;
      CX.fillStyle=v?'#261E3A':'#1E1630';
      CX.fillRect(tx,ty,ts,ts);
      // Grout lines between tiles
      CX.strokeStyle='#0E0A18';CX.lineWidth=1;
      CX.strokeRect(tx,ty,ts,ts);
    }

    // Stone cracks across tiles (stay in play area)
    CX.save();CX.strokeStyle='#0C0A16';CX.lineWidth=1;CX.globalAlpha=.7;
    for(let i=0;i<12;i++){
      const cx2=PX1+60+(Math.sin(i*37.1+seed)*.5+.5)*(PX2-PX1-120);
      const cy2=PY1+60+(Math.cos(i*19.3+seed)*.5+.5)*(PY2-PY1-120);
      CX.beginPath();CX.moveTo(cx2,cy2);
      CX.lineTo(cx2+Math.cos(i*1.2)*22+Math.sin(i*2.1)*10,cy2+Math.sin(i*1.2)*22);
      CX.lineTo(cx2+Math.cos(i*1.2)*38,cy2+Math.sin(i*1.2)*38+Math.cos(i)*8);
      CX.stroke();
    }
    CX.restore();

    // Dark stagnant water pools — low gloss on stone
    for(let i=0;i<3;i++){
      const px=PX1+100+(i*(PX2-PX1-200)/2);
      const py=PY1+80+Math.sin(i*2.3+seed)*80;
      CX.save();CX.globalAlpha=.5;
      const pg=CX.createRadialGradient(px,py,4,px,py,32);
      pg.addColorStop(0,'#0D0A1C');pg.addColorStop(.6,'#12101E');pg.addColorStop(1,'rgba(10,8,20,.2)');
      CX.fillStyle=pg;CX.beginPath();CX.ellipse(px,py,32,18,Math.sin(i)*.4,0,Math.PI*2);CX.fill();
      // Faint ripple
      CX.globalAlpha=.15;CX.strokeStyle='#2A2040';CX.lineWidth=.8;
      CX.beginPath();CX.ellipse(px,py,22,12,0,0,Math.PI*2);CX.stroke();
      CX.restore();
    }

    // Scattered bones — stay clearly inside play area
    const bones=[[180,170],[400,250],[620,190],[240,390],[520,410],[700,310],[160,480],[460,330]];
    bones.forEach(([bx,by],bi)=>{
      CX.save();CX.translate(bx,by);CX.rotate(Math.sin(bi*2.1+seed)*.8);
      CX.strokeStyle='rgba(210,200,175,.28)';CX.lineWidth=2;CX.lineCap='round';
      CX.beginPath();CX.moveTo(-13,0);CX.lineTo(13,0);CX.stroke();
      CX.fillStyle='rgba(195,185,155,.22)';
      [-13,13].forEach(ex=>{CX.beginPath();CX.arc(ex,0,4,0,Math.PI*2);CX.fill();});
      CX.restore();
    });

    // Spider webs in the 4 corners — inside the play area
    [[PX1+8,PY1+8],[PX2-8,PY1+8],[PX1+8,PY2-8],[PX2-8,PY2-8]].forEach(([wx,wy],wi)=>{
      CX.save();CX.globalAlpha=.3;CX.strokeStyle='#8888AA';CX.lineWidth=.5;
      const signs=[[1,1],[-1,1],[1,-1],[-1,-1]][wi];
      for(let sp=0;sp<5;sp++){
        const a=sp*(Math.PI*.5/4)+wi*(Math.PI*.5);
        CX.beginPath();CX.moveTo(wx,wy);
        CX.lineTo(wx+Math.cos(a)*44,wy+Math.sin(a)*44);CX.stroke();
      }
      for(let r=10;r<=40;r+=10){
        CX.beginPath();CX.arc(wx,wy,r,wi*(Math.PI*.5),(wi+1)*(Math.PI*.5));CX.stroke();
      }
      CX.restore();
    });

    // ── ONE LARGE DARK RUNE carved into the floor centre ──
    {
      const runeSyms=['⛧','☠','✝','☽','⬡'];
      const rSym=runeSyms[Math.floor(seed*3.7)%runeSyms.length];
      const cx2=W/2, cy2=H/2;
      const rs=72; // big
      CX.save();
      // Dark worn stone base — slightly darker than floor
      CX.fillStyle='rgba(10,8,18,.55)';
      CX.beginPath();CX.ellipse(cx2,cy2,rs+18,rs+8,0,0,Math.PI*2);CX.fill();
      // Outer carved ring — worn, not glowing
      CX.strokeStyle='rgba(90,70,120,.5)';CX.lineWidth=3;
      CX.beginPath();CX.arc(cx2,cy2,rs,0,Math.PI*2);CX.stroke();
      // Inner ring
      CX.strokeStyle='rgba(70,50,100,.4)';CX.lineWidth=1.5;
      CX.beginPath();CX.arc(cx2,cy2,rs*.65,0,Math.PI*2);CX.stroke();
      // 8 radial etching lines between the rings
      for(let i=0;i<8;i++){
        const a=i*Math.PI/4;
        CX.strokeStyle='rgba(80,55,110,.35)';CX.lineWidth=1;
        CX.beginPath();
        CX.moveTo(cx2+Math.cos(a)*rs*.65,cy2+Math.sin(a)*rs*.65);
        CX.lineTo(cx2+Math.cos(a)*rs,cy2+Math.sin(a)*rs);
        CX.stroke();
      }
      // Central symbol — dark, aged, carved not painted
      // No glow — just a dark etching like it was cut into the stone
      CX.fillStyle='rgba(50,35,75,.8)';
      CX.font='bold 88px serif';
      CX.textAlign='center';CX.textBaseline='middle';
      CX.fillText(rSym,cx2,cy2+4);
      // Very faint interior, slightly lighter than the symbol to show age
      CX.fillStyle='rgba(100,70,130,.18)';
      CX.font='bold 88px serif';
      CX.fillText(rSym,cx2+1,cy2+5);
      CX.restore();
    }

    // ── GRAVESTONES and STATUES in the corners ──
    const stoneCorners=[
      [PX1+55,PY1+70],[PX2-55,PY1+70],
      [PX1+55,PY2-60],[PX2-55,PY2-60]
    ];
    stoneCorners.forEach(([sx,sy],si)=>{
      CX.save();CX.translate(sx,sy);
      const wobble=Math.sin(si*2.3+seed)*.5+.5; // 0–1 per corner
      const isStatue=si%2===0; // alternating gravestone / statue

      if(isStatue){
        // ── CREEPY STATUE — robed figure on a plinth ──

        // Ground shadow
        CX.fillStyle='rgba(0,0,0,.4)';
        CX.beginPath();CX.ellipse(0,38,22,7,0,0,Math.PI*2);CX.fill();

        // Plinth base
        CX.fillStyle='#302840';CX.strokeStyle='#504060';CX.lineWidth=1.5;
        CX.beginPath();CX.roundRect(-20,24,40,16,2);CX.fill();CX.stroke();
        // Plinth step
        CX.fillStyle='#382E4A';CX.strokeStyle='#584870';CX.lineWidth=1;
        CX.beginPath();CX.roundRect(-16,16,32,10,1);CX.fill();CX.stroke();
        // Plinth crack
        CX.strokeStyle='rgba(0,0,0,.5)';CX.lineWidth=1;
        CX.beginPath();CX.moveTo(-4,18);CX.lineTo(-2,30);CX.stroke();

        // Robe lower — wide at base, narrowing up
        const robeG=CX.createLinearGradient(-14,14,14,14);
        robeG.addColorStop(0,'#2A2240');robeG.addColorStop(.5,'#3A3055');robeG.addColorStop(1,'#222038');
        CX.fillStyle=robeG;CX.strokeStyle='#4A4068';CX.lineWidth=1.5;
        CX.beginPath();
        CX.moveTo(-14,16);CX.lineTo(-12,-18);CX.lineTo(-6,-22);
        CX.lineTo(6,-22);CX.lineTo(12,-18);CX.lineTo(14,16);
        CX.closePath();CX.fill();CX.stroke();
        // Robe fold lines
        CX.strokeStyle='rgba(30,20,50,.7)';CX.lineWidth=1;
        CX.beginPath();CX.moveTo(-6,14);CX.lineTo(-5,-18);CX.stroke();
        CX.beginPath();CX.moveTo(4,14);CX.lineTo(3,-18);CX.stroke();

        // Arms crossed/tucked under robe
        CX.fillStyle='#2E2648';CX.strokeStyle='#4A3E66';CX.lineWidth=1;
        CX.beginPath();CX.roundRect(-12,-14,24,8,2);CX.fill();CX.stroke();

        // Hood / head
        CX.fillStyle='#2A2040';CX.strokeStyle='#403860';CX.lineWidth=1.5;
        CX.beginPath();
        CX.moveTo(-10,-22);CX.bezierCurveTo(-12,-32,-8,-40,0,-42);
        CX.bezierCurveTo(8,-40,12,-32,10,-22);
        CX.closePath();CX.fill();CX.stroke();
        // Hood shadow / face void
        CX.fillStyle='rgba(5,3,10,.95)';
        CX.beginPath();CX.ellipse(0,-30,5,7,0,0,Math.PI*2);CX.fill();
        // Faint pinprick eyes in the dark
        const eyePulse=.3+Math.sin(t*.8+si)*.2;
        CX.fillStyle=`rgba(180,140,255,${eyePulse})`;
        CX.beginPath();CX.arc(-2,-30,1.2,0,Math.PI*2);CX.fill();
        CX.beginPath();CX.arc(2,-30,1.2,0,Math.PI*2);CX.fill();
        // Weathering on robe
        CX.strokeStyle='rgba(0,0,0,.4)';CX.lineWidth=.8;
        CX.beginPath();CX.moveTo(-8,0);CX.lineTo(-7,8);CX.stroke();
        CX.beginPath();CX.moveTo(5,-4);CX.lineTo(6,4);CX.stroke();

      } else {
        // ── GRAVESTONE — weathered, leaning, moss-stained ──

        const lean=(si===1?.08:-.07); // lean direction

        // Ground shadow
        CX.fillStyle='rgba(0,0,0,.35)';
        CX.beginPath();CX.ellipse(4,10,26,7,0,0,Math.PI*2);CX.fill();

        // Soil mound at base
        CX.fillStyle='#1C1428';CX.strokeStyle='#2C2038';CX.lineWidth=1;
        CX.beginPath();CX.ellipse(0,12,22,8,lean,0,Math.PI*2);CX.fill();CX.stroke();

        CX.rotate(lean);

        // Stone body — granite grey
        const gsG=CX.createLinearGradient(-16,-60,16,-60);
        gsG.addColorStop(0,'#2E2A3C');gsG.addColorStop(.4,'#3E3A50');gsG.addColorStop(1,'#282438');
        CX.fillStyle=gsG;CX.strokeStyle='#504A68';CX.lineWidth=1.5;
        // Rounded arch top
        CX.beginPath();
        CX.moveTo(-14,8);CX.lineTo(-14,-44);
        CX.bezierCurveTo(-14,-62,14,-62,14,-44);
        CX.lineTo(14,8);CX.closePath();
        CX.fill();CX.stroke();

        // Stone cracks
        CX.strokeStyle='rgba(0,0,0,.55)';CX.lineWidth=1;
        CX.beginPath();CX.moveTo(-4,-20);CX.lineTo(-2,-8);CX.lineTo(-5,4);CX.stroke();
        CX.beginPath();CX.moveTo(5,-40);CX.lineTo(4,-30);CX.stroke();

        // Carved cross on stone
        CX.strokeStyle='rgba(80,65,105,.8)';CX.lineWidth=2.5;
        CX.beginPath();CX.moveTo(0,-54);CX.lineTo(0,-28);CX.stroke();
        CX.beginPath();CX.moveTo(-8,-44);CX.lineTo(8,-44);CX.stroke();

        // Worn inscription lines (just marks, no readable text)
        CX.strokeStyle='rgba(60,50,85,.6)';CX.lineWidth=1;
        CX.beginPath();CX.moveTo(-9,-16);CX.lineTo(9,-16);CX.stroke();
        CX.beginPath();CX.moveTo(-7,-10);CX.lineTo(7,-10);CX.stroke();
        CX.beginPath();CX.moveTo(-5,-4);CX.lineTo(6,-4);CX.stroke();

        // Moss patches — dark green stains
        CX.fillStyle='rgba(20,40,18,.55)';
        CX.beginPath();CX.ellipse(-6,-34,5,3,-.4,0,Math.PI*2);CX.fill();
        CX.beginPath();CX.ellipse(8,-24,4,2,.3,0,Math.PI*2);CX.fill();
        CX.beginPath();CX.ellipse(-3,0,6,3,0,0,Math.PI*2);CX.fill();
      }

      CX.restore();
    });

        // Boss room — pentagram and blood aura
    if(rm.type==='boss'){
      CX.save();CX.translate(W/2,H/2);CX.globalAlpha=.12+Math.sin(t*.7)*.04;
      CX.strokeStyle='#8B0000';CX.lineWidth=2;
      CX.beginPath();CX.arc(0,0,115,0,Math.PI*2);CX.stroke();
      CX.strokeStyle='#AA0000';CX.lineWidth=1.2;CX.beginPath();
      for(let i=0;i<5;i++){
        const a=i*(Math.PI*4/5)-Math.PI/2;
        i===0?CX.moveTo(Math.cos(a)*105,Math.sin(a)*105):CX.lineTo(Math.cos(a)*105,Math.sin(a)*105);
      }
      CX.closePath();CX.stroke();
      CX.restore();
      CX.save();CX.globalAlpha=.1;
      for(let i=0;i<5;i++){
        const bx=150+i*130,by=H/2+Math.sin(i*1.3)*80;
        const g=CX.createRadialGradient(bx,by,5,bx,by,70);
        g.addColorStop(0,'#8B0000');g.addColorStop(1,'transparent');
        CX.fillStyle=g;CX.beginPath();CX.ellipse(bx,by,70,35,i*.5,0,Math.PI*2);CX.fill();
      }
      CX.restore();
    }

    // Ambient purple mist near the floor edges
    CX.save();CX.globalAlpha=.05+Math.sin(t*.4)*.02;
    for(let i=0;i<3;i++){
      const fx=140+i*310,fy=H*.72;
      const g=CX.createRadialGradient(fx,fy,10,fx,fy,130);
      g.addColorStop(0,'#3A2A50');g.addColorStop(1,'transparent');
      CX.fillStyle=g;CX.fillRect(0,0,W,H);
    }
    CX.restore();

  } else if(theme==='liminal'){
    // ── BACKROOMS — wrong, endless, no way out ───────────────
    // Base carpet — mottled yellow-brown
    CX.fillStyle='#B8A870';CX.fillRect(0,0,W,H);

    // Carpet pattern — repeating diamond/square tile
    const cs=38;
    for(let tx=0;tx<W;tx+=cs)for(let ty=0;ty<H;ty+=cs){
      const ix=Math.floor(tx/cs),iy=Math.floor(ty/cs);
      // Alternating subtle pattern colours
      const base=(ix+iy)%4;
      const col=['#B4A468','#BCA870','#B0A064','#BAA66C'][base];
      CX.fillStyle=col;CX.fillRect(tx,ty,cs,cs);
      // Diamond inset
      CX.save();CX.globalAlpha=.12;
      CX.strokeStyle='#8A7840';CX.lineWidth=.8;
      const mx=tx+cs/2,my=ty+cs/2,dr=cs*.38;
      CX.beginPath();CX.moveTo(mx,my-dr);CX.lineTo(mx+dr,my);CX.lineTo(mx,my+dr);CX.lineTo(mx-dr,my);CX.closePath();CX.stroke();
      CX.restore();
    }

    // Stains — dark, spread across floor, different sizes
    const stainPos=[
      [180,200,60,35],[450,380,80,45],[650,220,50,30],
      [280,440,70,40],[580,140,55,32],[120,340,45,28],
      [760,400,65,38],[400,260,42,25],
    ];
    stainPos.forEach(([sx,sy,srx,sry],si)=>{
      const sangle=Math.sin(si*1.9+seed)*.5;
      CX.save();CX.globalAlpha=.18+Math.sin(si*2.3)*.06;
      const sg=CX.createRadialGradient(sx,sy,4,sx,sy,srx);
      sg.addColorStop(0,'rgba(60,45,20,.9)');sg.addColorStop(.5,'rgba(50,38,15,.5)');sg.addColorStop(1,'transparent');
      CX.fillStyle=sg;CX.beginPath();CX.ellipse(sx,sy,srx,sry,sangle,0,Math.PI*2);CX.fill();
      CX.restore();
    });

    // Recurring identical doorways drawn on the floor — wrong perspective, too many
    CX.save();CX.globalAlpha=.12;
    CX.strokeStyle='#9A8850';CX.lineWidth=2;
    // Fake receding perspective doorframes on the floor surface
    [[150,H*.4],[W/2,H*.35],[W-150,H*.4]].forEach(([dx,dy])=>{
      // Outer frame
      CX.strokeRect(dx-30,dy-50,60,70);
      // Inner frame (receding)
      CX.strokeRect(dx-22,dy-42,44,55);
      // Threshold line
      CX.beginPath();CX.moveTo(dx-30,dy+20);CX.lineTo(dx+30,dy+20);CX.stroke();
    });
    CX.restore();

    // Fluorescent light shadows on floor — long rectangular shadows
    CX.save();CX.globalAlpha=.07;
    CX.fillStyle='#FFFFAA';
    [[W*.2,0,60,H],[W*.5,0,55,H],[W*.78,0,50,H]].forEach(([lx,ly,lw,lh])=>{
      const flk2=Math.sin(t*55+seed+lx)>.96?.2:1;
      CX.globalAlpha=.07*flk2;
      CX.fillRect(lx-lw/2,ly,lw,lh);
    });
    CX.restore();

    // Wrong shadows — shadows pointing the wrong direction, no light source
    CX.save();CX.globalAlpha=.1;
    for(let i=0;i<5;i++){
      const shx=120+i*160, shy=PY1+40+Math.sin(i*2.1+seed)*80;
      const slen=60+Math.sin(i*1.7)*20;
      // Shadow stretching toward camera (wrong)
      const shg=CX.createLinearGradient(shx,shy,shx+Math.sin(i)*(slen*.4),shy+slen);
      shg.addColorStop(0,'rgba(40,30,10,.7)');shg.addColorStop(1,'transparent');
      CX.fillStyle=shg;
      CX.beginPath();CX.moveTo(shx-8,shy);CX.lineTo(shx+8,shy);
      CX.lineTo(shx+14+Math.sin(i)*5,shy+slen);CX.lineTo(shx-14,shy+slen);CX.closePath();CX.fill();
    }
    CX.restore();

    // Fluorescent overall tint — sickly yellow-green
    const flicker3=Math.sin(t*58+seed)>.96?.4:.95+Math.sin(t*.1)*.05;
    CX.save();CX.globalAlpha=.08*flicker3;
    CX.fillStyle='#CCDD44';CX.fillRect(0,0,W,H);
    CX.restore();

    // Wet patch — "CAUTION" not visible, just the sheen
    CX.save();CX.globalAlpha=.09+Math.sin(t*.4)*.02;
    CX.fillStyle='#DDDDCC';
    CX.beginPath();CX.ellipse(W*.65,H*.6,110,38,-.25,0,Math.PI*2);CX.fill();
    CX.restore();

  } else if(theme==='forest'){
    // Dark mossy forest floor
    CX.fillStyle='#060C04';CX.fillRect(0,0,W,H);
    // Mossy ground patches
    for(let i=0;i<30;i++){
      const px=(Math.sin(i*73.1+seed)*0.5+0.5)*W;
      const py=(Math.cos(i*37.7+seed)*0.5+0.5)*H;
      const r=25+Math.sin(i*11.3)*12;
      const g=CX.createRadialGradient(px,py,2,px,py,r);
      g.addColorStop(0,'#1A2A0A');g.addColorStop(1,'transparent');
      CX.fillStyle=g;CX.beginPath();CX.arc(px,py,r,0,Math.PI*2);CX.fill();
    }
    // Moonbeam shafts from above
    CX.save();CX.globalAlpha=.07+Math.sin(t*.18)*.025;
    for(let i=0;i<3;i++){
      const bx=140+i*280+Math.sin(t*.08+i)*15;
      const g=CX.createLinearGradient(bx,0,bx+55,H);
      g.addColorStop(0,'rgba(180,210,255,.9)');g.addColorStop(.6,'rgba(180,210,255,.2)');g.addColorStop(1,'transparent');
      CX.fillStyle=g;CX.fillRect(bx,0,55,H);
    }
    CX.restore();
    // Trees along the walls — trunks + canopy
    const treePositions=[
      [WT+28,PY1+20],[WT+28,PY2-20],
      [PX2-28,PY1+20],[PX2-28,PY2-20],
      [W/2-130,PY1+10],[W/2+130,PY1+10],
      [W/2-130,PY2-10],[W/2+130,PY2-10],
    ];
    treePositions.forEach(([tx,ty],idx)=>{
      CX.save();CX.translate(tx,ty);
      const lean=Math.sin(t*.4+idx*.8)*.03;
      CX.rotate(lean);
      // Trunk
      const trH=55+Math.sin(idx*3.7)*15;
      const g2=CX.createLinearGradient(-6,0,6,0);
      g2.addColorStop(0,'#1A0E04');g2.addColorStop(.5,'#2A1A08');g2.addColorStop(1,'#0E0802');
      CX.fillStyle=g2;
      CX.beginPath();CX.moveTo(-5,0);CX.lineTo(-7,-trH);CX.lineTo(7,-trH);CX.lineTo(5,0);CX.closePath();CX.fill();
      // Roots spreading out
      CX.strokeStyle='#1A1004';CX.lineWidth=2;
      for(let r=0;r<3;r++){
        const ra=(r-1)*.5;
        CX.beginPath();CX.moveTo(0,0);
        CX.quadraticCurveTo(18*Math.cos(ra),12,32*Math.cos(ra),4);CX.stroke();
      }
      // Canopy layers (3 overlapping dark circles)
      const cr=28+Math.sin(idx*2.1)*8;
      [[0,-trH-cr*.4,cr*1.1],[cr*.4,-trH-cr*.7,cr*.85],[-cr*.4,-trH-cr*.6,cr*.9]].forEach(([ox,oy,or])=>{
        const cg=CX.createRadialGradient(ox,oy,or*.2,ox,oy,or);
        cg.addColorStop(0,'#0A1A05');cg.addColorStop(.5,'#0D2208');cg.addColorStop(1,'rgba(5,12,2,.3)');
        CX.fillStyle=cg;CX.beginPath();CX.arc(ox,oy,or,0,Math.PI*2);CX.fill();
      });
      // Glowing eyes in the dark canopy (sometimes)
      if(Math.sin(idx*7.3+t*.2)>.6){
        CX.fillStyle='#AAFF44';CX.shadowColor='#88FF22';CX.shadowBlur=6;
        CX.beginPath();CX.ellipse(-5,-trH-cr*.7,2,1.5,0,0,Math.PI*2);CX.fill();
        CX.beginPath();CX.ellipse(3,-trH-cr*.7,2,1.5,0,0,Math.PI*2);CX.fill();
        CX.shadowBlur=0;
      }
      CX.restore();
    });
    // Mushrooms on the ground
    for(let i=0;i<5;i++){
      const mx=PX1+80+(i*(PX2-PX1-160)/4);
      const my=PY2-30+Math.sin(i*2.3+seed)*20;
      CX.save();CX.translate(mx,my);
      // Stem
      CX.fillStyle='#C8B888';
      CX.beginPath();CX.roundRect(-3,-16,6,16,1);CX.fill();
      // Cap
      const capCol=i%2===0?'#CC3333':'#FF8833';
      CX.fillStyle=capCol;CX.shadowColor=capCol;CX.shadowBlur=6;
      CX.beginPath();CX.ellipse(0,-16,10,7,0,Math.PI,0);CX.fill();
      // Spots on cap
      CX.fillStyle='rgba(255,255,255,.7)';CX.shadowBlur=0;
      [[-3,-19],[3,-20],[0,-22]].forEach(([sx,sy])=>{
        CX.beginPath();CX.arc(sx,sy,1.5,0,Math.PI*2);CX.fill();
      });
      CX.restore();
    }
    // Ground roots snaking across floor
    CX.save();CX.strokeStyle='#1E1208';CX.lineWidth=2.5;CX.globalAlpha=.6;
    for(let i=0;i<6;i++){
      const rx=(Math.sin(i*53+seed)*0.4+0.3)*W;
      const ry=PY1+80+(Math.cos(i*29+seed)*0.4+0.3)*(PY2-PY1-160);
      CX.beginPath();CX.moveTo(rx,ry);
      CX.bezierCurveTo(rx+60,ry-25,rx+100,ry+30,rx+170,ry+5);CX.stroke();
      CX.beginPath();CX.moveTo(rx+40,ry-10);
      CX.bezierCurveTo(rx+55,ry+20,rx+70,ry+10,rx+90,ry+25);CX.stroke();
    }
    CX.restore();
    // Fog wisps near the ground
    CX.save();CX.globalAlpha=.06+Math.sin(t*.3)*.02;
    for(let i=0;i<4;i++){
      const fx=((Math.sin(t*.12+i*1.6)+1)/2)*W;
      const g=CX.createRadialGradient(fx,PY2-20,5,fx,PY2-20,80);
      g.addColorStop(0,'rgba(180,220,180,.8)');g.addColorStop(1,'transparent');
      CX.fillStyle=g;CX.fillRect(0,0,W,H);
    }
    CX.restore();
    // Fireflies
    for(let i=0;i<8;i++){
      const fx=PX1+50+((Math.sin(t*.28+i*1.7)+1)/2)*(PX2-PX1-100);
      const fy=PY1+40+((Math.cos(t*.22+i*2.3)+1)/2)*(PY2-PY1-80);
      const fade=Math.max(0,Math.sin(t*1.8+i*3));
      CX.save();CX.globalAlpha=fade*.8;
      CX.fillStyle='#CCFF88';CX.shadowColor='#AAFF44';CX.shadowBlur=10+fade*6;
      CX.beginPath();CX.arc(fx,fy,2.5,0,Math.PI*2);CX.fill();
      CX.shadowBlur=0;CX.restore();
    }

  } else if(theme==='candyland'){
    // Pastel horror — sweet on the surface, rotten underneath
    CX.fillStyle='#EEB8D8';CX.fillRect(0,0,W,H);
    // Checkerboard candy tiles
    const ts2=52;
    const candyCols=['#F8D0EC','#EEC8F0','#D8ECF8','#F8F0C8','#D8F0E4'];
    for(let tx=0;tx<W;tx+=ts2)for(let ty=0;ty<H;ty+=ts2){
      CX.fillStyle=candyCols[Math.floor((tx/ts2+ty/ts2+seed*0.1)%5)];
      CX.fillRect(tx,ty,ts2,ts2);
      CX.save();CX.globalAlpha=.12;
      CX.strokeStyle='rgba(255,100,180,.5)';CX.lineWidth=1;
      CX.strokeRect(tx,ty,ts2,ts2);
      CX.restore();
    }
    // Melted sugar puddles on the floor
    for(let i=0;i<6;i++){
      const px=PX1+70+(i*(PX2-PX1-140)/5);
      const py=PY1+60+(Math.sin(i*2.1+seed)*0.4+0.4)*(PY2-PY1-120);
      const pr=25+Math.sin(i*3.7)*10;
      CX.save();CX.globalAlpha=.55;
      const pg=CX.createRadialGradient(px,py,2,px,py,pr);
      const puddleCols=['#FF6688','#FF88AA','#FFAACC','#FF44AA'];
      pg.addColorStop(0,puddleCols[i%4]);pg.addColorStop(.6,puddleCols[(i+1)%4]+'88');pg.addColorStop(1,'transparent');
      CX.fillStyle=pg;CX.beginPath();CX.ellipse(px,py,pr,pr*.6,Math.sin(i)*.5,0,Math.PI*2);CX.fill();
      CX.restore();
    }
    // Lollipops — round candy on a stick
    const lolliPos=[[PX1+45,PY1+80],[PX2-45,PY1+80],[PX1+45,PY2-80],[PX2-45,PY2-80],[W/2,PY1+60],[W/2,PY2-60]];
    lolliPos.forEach(([lx,ly],li)=>{
      const sway=Math.sin(t*.6+li*.9)*.04;
      CX.save();CX.translate(lx,ly);CX.rotate(sway);
      // Stick
      CX.strokeStyle='#C8A870';CX.lineWidth=3;CX.lineCap='round';
      CX.beginPath();CX.moveTo(0,0);CX.lineTo(0,32);CX.stroke();
      // Candy swirl (3 colour layers)
      const lCols=[['#FF4488','#FF88BB'],['#FF8800','#FFCC44'],['#8844FF','#CC88FF'],['#FF2244','#FF8866']];
      const [c1,c2]=lCols[li%4];
      const lr=16;
      // Outer candy
      CX.fillStyle=c1;CX.shadowColor=c1;CX.shadowBlur=8+Math.sin(t+li)*3;
      CX.beginPath();CX.arc(0,0,lr,0,Math.PI*2);CX.fill();
      // Swirl stripe
      CX.save();CX.rotate(t*.5+li);
      CX.fillStyle=c2;
      for(let s=0;s<3;s++){
        CX.beginPath();
        CX.moveTo(0,0);
        CX.arc(0,0,lr,s*(Math.PI*2/3),s*(Math.PI*2/3)+Math.PI/4);
        CX.closePath();CX.fill();
      }
      CX.restore();
      // Shine
      CX.fillStyle='rgba(255,255,255,.4)';
      CX.beginPath();CX.ellipse(-5,-5,5,3,-.5,0,Math.PI*2);CX.fill();
      CX.shadowBlur=0;CX.restore();
    });
    // Candy canes — vertical striped sticks near walls
    [[PX1+22,H/2-60],[PX1+22,H/2+60],[PX2-22,H/2-60],[PX2-22,H/2+60]].forEach(([cx3,cy3])=>{
      CX.save();CX.translate(cx3,cy3);
      // Cane shaft
      for(let s=0;s<8;s++){
        CX.fillStyle=s%2===0?'#FF3366':'#FFFFFF';
        CX.fillRect(-5,s*8-32,10,8);
      }
      // Curved top
      CX.strokeStyle='#FF3366';CX.lineWidth=10;CX.lineCap='round';
      CX.beginPath();CX.arc(5,-32,10,Math.PI,0);CX.stroke();
      CX.strokeStyle='#FFFFFF';CX.lineWidth=4;
      CX.beginPath();CX.arc(5,-32,10,Math.PI,0);CX.stroke();
      CX.restore();
    });
    // Dark corruption drips from ceiling — sugar gone wrong
    CX.save();
    for(let i=0;i<14;i++){
      const cx4=40+i*(W-80)/13+Math.sin(i*2.1+seed)*12;
      const drip=20+Math.sin(t*.4+i*.8+seed)*12;
      const dg=CX.createLinearGradient(cx4,0,cx4,drip+14);
      dg.addColorStop(0,'rgba(100,0,50,.85)');dg.addColorStop(1,'transparent');
      CX.fillStyle=dg;
      CX.beginPath();CX.moveTo(cx4-3,0);
      CX.quadraticCurveTo(cx4,drip*.5,cx4+1,drip);
      CX.ellipse(cx4,drip+5,3,4,0,0,Math.PI*2);CX.fill();
    }
    CX.restore();
    // Wrong pulsing glow — something evil under the sweetness
    CX.save();CX.globalAlpha=.07+Math.sin(t*.5)*.03;
    for(let i=0;i<3;i++){
      const px=200+i*250,py=H*.5+Math.sin(t*.35+i)*60;
      const dkg=CX.createRadialGradient(px,py,10,px,py,130);
      dkg.addColorStop(0,'#880033');dkg.addColorStop(1,'transparent');
      CX.fillStyle=dkg;CX.fillRect(0,0,W,H);
    }
    CX.restore();

  } else if(theme==='void'){
    // Glitched void — corrupted reality
    CX.fillStyle='#020208';CX.fillRect(0,0,W,H);
    // Moving grid (cheap — just lines)
    const gs=55;
    const goff=(t*20)%gs;
    CX.strokeStyle='#1A1A44';CX.lineWidth=.5;
    for(let gx=goff;gx<W;gx+=gs){CX.beginPath();CX.moveTo(gx,0);CX.lineTo(gx,H);CX.stroke();}
    for(let gy=goff;gy<H;gy+=gs){CX.beginPath();CX.moveTo(0,gy);CX.lineTo(W,gy);CX.stroke();}
    // Glitch scanlines (just a few horizontal bars)
    CX.save();CX.globalAlpha=.18;
    const gY=Math.floor(t*4)%H;
    CX.fillStyle='#6666FF';CX.fillRect(0,gY,W,3);
    CX.fillStyle='#FF3333';CX.fillRect(0,(gY+120)%H,W,2);
    CX.fillStyle='#33FF33';CX.fillRect(0,(gY+240)%H,W,1);
    CX.restore();
    // Void portal glows
    for(let i=0;i<3;i++){
      const px=150+i*300,py=H/2+Math.sin(t*.4+i*2)*80;
      CX.save();CX.globalAlpha=.07+Math.sin(t+i)*.03;
      const vg=CX.createRadialGradient(px,py,5,px,py,70);
      vg.addColorStop(0,'#6633FF');vg.addColorStop(1,'transparent');
      CX.fillStyle=vg;CX.fillRect(0,0,W,H);
      CX.restore();
    }
  }
}

function drawWalls(rm){
  const t=Date.now()/1000;
  const theme=rm.theme||'dungeon';
  const seed=rm._seed||0;

  // Wall colors per theme
  const wallColors={
    dungeon:{wall:'#080510',brick:'#0F0A1A',trim:'#160E24',drip:'#8B0000'},
    liminal:{wall:'#A89850',brick:'#907830',trim:'#786020',drip:'#886600'},
    forest: {wall:'#0A1205',brick:'#121A08',trim:'#1A2A10',drip:'#1A3A08'},
    candyland:{wall:'#D060A0',brick:'#C04888',trim:'#B83878',drip:'#880044'},
    void:   {wall:'#080818',brick:'#10103A',trim:'#181850',drip:'#2222AA'},
  };
  const wc=wallColors[theme]||wallColors.dungeon;
  CX.fillStyle=wc.wall;
  CX.fillRect(0,0,W,WT);CX.fillRect(0,H-WT,W,WT);
  CX.fillRect(0,0,WT,H);CX.fillRect(W-WT,0,WT,H);
  CX.strokeStyle=wc.brick;CX.lineWidth=1;
  const bh=18,bw=48;
  for(let row=0;row<3;row++){
    const off=(row%2)*bw*.5;
    for(let col=-1;col<W/bw+2;col++){
      CX.strokeRect(col*bw+off,row*bh,bw,bh);
      CX.strokeRect(col*bw+off,H-WT+row*bh,bw,bh);
    }
    for(let col=-1;col<H/bh+2;col++){
      CX.strokeRect(row*bh,col*bh,bh,bh);
      CX.strokeRect(W-WT+row*bh,col*bh,bh,bh);
    }
  }
  CX.strokeStyle=wc.trim;CX.lineWidth=1.5;CX.strokeRect(WT,WT,W-WT*2,H-WT*2);
  // Blood/theme drips from ceiling
  CX.save();CX.globalAlpha=.55;
  for(let i=0;i<8;i++){
    const dx=60+i*105,dlen=12+Math.sin(i*3.7)*10;
    const g=CX.createLinearGradient(dx,0,dx,dlen+8);
    g.addColorStop(0,wc.drip);g.addColorStop(1,'transparent');
    CX.fillStyle=g;
    CX.beginPath();CX.moveTo(dx-2,0);
    CX.quadraticCurveTo(dx,dlen*.5,dx-1+Math.sin(i)*2,dlen);
    CX.ellipse(dx,dlen+3,2.5,3,0,0,Math.PI*2);CX.fill();
  }
  CX.restore();
  // Dungeon wall runes — bright purple, clearly visible
  if(theme==='dungeon'){
    const wallRuneSet=['☽','⛧','✦','☠','⬡','☿','✝','⚰'];
    CX.save();
    // Top and bottom walls
    wallRuneSet.forEach((rune,i)=>{
      const rx=70+i*115, topY=WT*.5, botY=H-WT*.5;
      CX.fillStyle='rgba(8,5,16,.9)';
      CX.beginPath();CX.arc(rx,topY,11,0,Math.PI*2);CX.fill();
      CX.beginPath();CX.arc(rx,botY,11,0,Math.PI*2);CX.fill();
      CX.fillStyle='rgba(210,160,255,.8)';CX.font='bold 14px serif';
      CX.textAlign='center';CX.textBaseline='middle';
      CX.shadowColor='#BB77FF';CX.shadowBlur=7;
      CX.fillText(rune,rx,topY);CX.fillText(rune,rx,botY);
      CX.shadowBlur=0;
    });
    // Side walls
    for(let wy=PY1+50;wy<PY2-30;wy+=85){
      [[WT*.5,wy],[W-WT*.5,wy]].forEach(([wx,wy2])=>{
        const ri=Math.floor((wx*0.01+wy2*0.01+seed)%wallRuneSet.length);
        CX.fillStyle='rgba(8,5,16,.9)';
        CX.beginPath();CX.arc(wx,wy2,10,0,Math.PI*2);CX.fill();
        CX.fillStyle='rgba(210,160,255,.75)';CX.font='bold 13px serif';
        CX.textAlign='center';CX.textBaseline='middle';
        CX.shadowColor='#BB77FF';CX.shadowBlur=6;
        CX.fillText(wallRuneSet[ri],wx,wy2);CX.shadowBlur=0;
      });
    }
    CX.restore();
  }

  // Lights — torches for dungeon/forest/void, fluorescent for liminal, candy lamp for candyland
  if(theme==='liminal'){
    // Fluorescent tubes — some dead, some flickering
    const tubes=[[W*.2,WT+5,100],[W*.55,WT+5,90],[W*.82,WT+5,80],[W*.38,H-WT-5,110],[W*.7,H-WT-5,85]];
    tubes.forEach(([lx,ly,llen],li)=>{
      const dead=Math.sin(seed*3.1+li*7.3)>.55;
      const flk=dead?0:Math.sin(t*(50+li*7)+seed+li)>.93?.15:1;
      if(flk<.2&&!dead) return; // tube fully off this frame
      CX.save();CX.globalAlpha=(.6+Math.sin(t*.1+li)*.05)*flk;
      CX.fillStyle=dead?'#555544':'#EEEEBB';
      CX.shadowColor=dead?'none':'#FFFFAA';CX.shadowBlur=dead?0:14;
      CX.fillRect(lx-llen/2,ly-3,llen,5);
      // End caps
      CX.fillStyle=dead?'#333322':'#CCCCAA';
      CX.fillRect(lx-llen/2-4,ly-4,5,7);CX.fillRect(lx+llen/2,ly-4,5,7);
      CX.shadowBlur=0;CX.restore();
      // Light pool on floor (only alive tubes)
      if(!dead&&flk>.3){
        CX.save();CX.globalAlpha=.05*flk;
        const lg=CX.createLinearGradient(lx,ly,lx,ly+(ly<H/2?120:-120));
        lg.addColorStop(0,'#FFFFCC');lg.addColorStop(1,'transparent');
        CX.fillStyle=lg;CX.fillRect(lx-llen*.6,ly,llen*1.2,ly<H/2?120:-120);
        CX.restore();
      }
    });
    // Wallpaper pattern on side walls — repeating identical motif
    CX.save();CX.globalAlpha=.18;
    for(let wy=WT+10;wy<H-WT;wy+=28){
      for(const wx of [WT*.3,WT*.7,W-WT*.7,W-WT*.3]){
        CX.fillStyle='#8A7030';CX.font='10px serif';
        CX.textAlign='center';CX.textBaseline='middle';
        CX.fillText('❧',wx,wy);
      }
    }
    CX.restore();
    // Wrong doorway outlines on walls (should not be there)
    CX.save();CX.globalAlpha=.2;CX.strokeStyle='#887730';CX.lineWidth=2;
    [[WT*.5,H*.4],[W-WT*.5,H*.4]].forEach(([wx,wy])=>{
      CX.strokeRect(wx-14,wy-28,28,48);
      CX.strokeRect(wx-10,wy-24,20,36);
    });
    CX.restore();
  } else if(theme==='candyland'){
    // Candy-stripe lollipop lights
    [[WT+18,H/2],[W-WT-18,H/2],[W/2,WT+18],[W/2,H-WT-18]].forEach(([lx,ly])=>{
      CX.save();CX.translate(lx,ly);
      CX.fillStyle='#FF88CC';CX.strokeStyle='#FF44AA';CX.lineWidth=2;
      CX.shadowColor='#FF88CC';CX.shadowBlur=12+Math.sin(t*2+seed)*4;
      CX.beginPath();CX.arc(0,0,10,0,Math.PI*2);CX.fill();CX.stroke();
      CX.fillStyle='#FF44AA';CX.beginPath();CX.arc(0,0,5,0,Math.PI*2);CX.fill();
      CX.shadowBlur=0;CX.restore();
    });
  } else if(theme==='void'){
    // Pulsing void portals instead of torches
    [[WT+18,H/2],[W-WT-18,H/2],[W/2,WT+18],[W/2,H-WT-18]].forEach(([lx,ly],i)=>{
      CX.save();CX.translate(lx,ly);
      const pulse=.8+Math.sin(t*2+i)*.2;
      CX.shadowColor='#6633FF';CX.shadowBlur=16*pulse;
      CX.fillStyle='#330099';CX.strokeStyle='#6633FF';CX.lineWidth=1.5;
      CX.beginPath();CX.arc(0,0,8,0,Math.PI*2);CX.fill();CX.stroke();
      CX.shadowBlur=0;CX.restore();
    });
  } else {
    for(const [tx,ty] of [[WT+18,H/2],[W-WT-18,H/2],[W/2,WT+18],[W/2,H-WT-18]])
      drawTorch(tx,ty,t,rm._flicker||seed);
  }

  // Carve door openings — use floor color so transition looks natural per theme
  const floorBg={dungeon:'#1A1428',liminal:'#B8A870',forest:'#060C04',
                  candyland:'#EEB8D8',void:'#020208'}[theme]||'#08060E';
  const cl=rm.cleared;
  if(rm.doors.U){
    CX.fillStyle=floorBg;CX.fillRect(W/2-DHW,0,DW,WT+1);
    cl?drawOpenArch(W/2,WT,'up'):drawGate(W/2-DHW,0,DW,WT,'h');
  }
  if(rm.doors.D){
    CX.fillStyle=floorBg;CX.fillRect(W/2-DHW,H-WT-1,DW,WT+1);
    cl?drawOpenArch(W/2,H-WT,'down'):drawGate(W/2-DHW,H-WT,DW,WT,'h');
  }
  if(rm.doors.L){
    CX.fillStyle=floorBg;CX.fillRect(0,H/2-DHW,WT+1,DW);
    cl?drawOpenArch(WT,H/2,'left'):drawGate(0,H/2-DHW,WT,DW,'v');
  }
  if(rm.doors.R){
    CX.fillStyle=floorBg;CX.fillRect(W-WT-1,H/2-DHW,WT+1,DW);
    cl?drawOpenArch(W-WT,H/2,'right'):drawGate(W-WT,H/2-DHW,WT,DW,'v');
  }
}

function drawTorch(x,y,t,off){
  const fl=Math.sin(t*5.3+off)*1.8+Math.cos(t*3.1+off)*1.2;
  CX.save();CX.translate(x,y);
  CX.fillStyle='#2A2240';CX.beginPath();CX.roundRect(-5,-10,10,16,2);CX.fill();
  const g=CX.createRadialGradient(0,-14,2,0,-14,18+fl);
  g.addColorStop(0,'rgba(255,200,60,.8)');g.addColorStop(.4,'rgba(200,80,20,.4)');g.addColorStop(1,'transparent');
  CX.fillStyle=g;CX.shadowColor='#FF8800';CX.shadowBlur=12+fl*3;
  CX.beginPath();CX.ellipse(0,-14,4+fl*.4,7+fl*.3,0,0,Math.PI*2);CX.fill();
  CX.shadowBlur=0;CX.restore();
}

function drawOpenArch(ax,ay,dir){
  CX.save();
  // Large glow pool first (drawn under pillars)
  const gx=dir==='left'?ax+70:dir==='right'?ax-70:ax;
  const gy=dir==='up'?ay+70:dir==='down'?ay-70:ay;
  const g=CX.createRadialGradient(gx,gy,5,gx,gy,110);
  g.addColorStop(0,'rgba(218,165,32,.55)');
  g.addColorStop(.4,'rgba(184,134,11,.25)');
  g.addColorStop(1,'transparent');
  CX.fillStyle=g;CX.fillRect(gx-110,gy-110,220,220);
  // Bright doorframe pillars with strong glow
  CX.strokeStyle='#FFD060';CX.lineWidth=4;
  CX.shadowColor='#FFD060';CX.shadowBlur=22;
  CX.beginPath();
  if(dir==='up'||dir==='down'){
    const sign=dir==='up'?1:-1;
    CX.moveTo(ax-DHW,ay);CX.lineTo(ax-DHW,ay+sign*24);
    CX.moveTo(ax+DHW,ay);CX.lineTo(ax+DHW,ay+sign*24);
  } else {
    const sign=dir==='left'?1:-1;
    CX.moveTo(ax,ay-DHW);CX.lineTo(ax+sign*24,ay-DHW);
    CX.moveTo(ax,ay+DHW);CX.lineTo(ax+sign*24,ay+DHW);
  }
  CX.stroke();
  CX.shadowBlur=0;CX.restore();
}

function drawGate(x,y,w,h,dir){
  // Bright red gate bars — clearly locked
  CX.strokeStyle='#CC2222';CX.lineWidth=3;
  CX.shadowColor='#FF0000';CX.shadowBlur=8;
  const n=4;
  if(dir==='h'){
    for(let i=1;i<=n;i++){
      const bx=x+i*(w/(n+1));
      CX.beginPath();CX.moveTo(bx,y);CX.lineTo(bx,y+h);CX.stroke();
      // Spike tip
      CX.beginPath();CX.moveTo(bx-3,y+2);CX.lineTo(bx,y-7);CX.lineTo(bx+3,y+2);CX.stroke();
    }
  } else {
    for(let i=1;i<=n;i++){
      const by=y+i*(h/(n+1));
      CX.beginPath();CX.moveTo(x,by);CX.lineTo(x+w,by);CX.stroke();
      CX.beginPath();CX.moveTo(x+2,by-3);CX.lineTo(x-7,by);CX.lineTo(x+2,by+3);CX.stroke();
    }
  }
  CX.shadowBlur=0;
}

function drawObs(obs){
  obs.forEach(o=>{
    CX.save();CX.translate(o.x,o.y);
    // Drop shadow so obstacles lift off floor
    CX.fillStyle='rgba(0,0,0,.7)';CX.fillRect(-o.w/2+5,6,o.w,o.h);
    if(o.kind==='pillar'){
      // Stone pillar — clearly grey/beige, not purple
      const g=CX.createLinearGradient(-o.w/2,0,o.w/2,0);
      g.addColorStop(0,'#3A3248');g.addColorStop(.45,'#4A405E');g.addColorStop(1,'#2E2840');
      CX.fillStyle=g;CX.strokeStyle='#6A5A80';CX.lineWidth=1.5;
      CX.beginPath();CX.roundRect(-o.w/2,-o.h/2,o.w,o.h,3);CX.fill();CX.stroke();
      // Cap bands — brighter than body
      CX.fillStyle='#5A5070';
      CX.fillRect(-o.w/2-2,-o.h/2,o.w+4,6);
      CX.fillRect(-o.w/2-2,o.h/2-6,o.w+4,6);
      // Bright edge highlight
      CX.strokeStyle='rgba(180,160,220,.35)';CX.lineWidth=1;
      CX.beginPath();CX.moveTo(-o.w/2+2,-o.h/2+7);CX.lineTo(-o.w/2+2,o.h/2-7);CX.stroke();
      // Symbol
      CX.fillStyle='rgba(200,150,255,.35)';CX.font=`${o.w*.42}px serif`;
      CX.textAlign='center';CX.textBaseline='middle';
      CX.fillText(['⛧','☽','⬡','✦','☿'][Math.floor(o._r*5)],0,0);
    } else {
      // Crypt sarcophagus — dark reddish stone, clearly different from floor
      const g2=CX.createLinearGradient(0,-o.h/2,0,o.h/2);
      g2.addColorStop(0,'#2E1A14');g2.addColorStop(.5,'#3A2018');g2.addColorStop(1,'#221410');
      CX.fillStyle=g2;CX.strokeStyle='#7A3A28';CX.lineWidth=1.5;
      CX.beginPath();CX.roundRect(-o.w/2,-o.h/2,o.w,o.h,2);CX.fill();CX.stroke();
      // Lid seam line
      CX.strokeStyle='rgba(200,100,60,.4)';CX.lineWidth=1;
      CX.beginPath();CX.moveTo(-o.w/2+4,0);CX.lineTo(o.w/2-4,0);CX.stroke();
      // Cross marks — clearly visible
      CX.strokeStyle='rgba(220,100,80,.5)';CX.lineWidth=1.5;
      const cx2=0,cy2=0;
      CX.beginPath();CX.moveTo(cx2-8,-o.h*.25);CX.lineTo(cx2+8,-o.h*.25);CX.stroke();
      CX.beginPath();CX.moveTo(cx2,-o.h*.25-8);CX.lineTo(cx2,-o.h*.25+8);CX.stroke();
      // Skull
      CX.fillStyle='rgba(255,120,80,.3)';CX.font=`${o.h*.45}px serif`;
      CX.textAlign='center';CX.textBaseline='middle';CX.fillText('☠',0,o.h*.18);
    }
    CX.restore();
  });
}

function drawRoomDeco(rm){
  const t=Date.now()/1000;
  if(rm.type==='shop'){
    // Shop header
    CX.fillStyle='rgba(184,134,11,.7)';CX.font='bold 14px Creepster,cursive';
    CX.textAlign='center';CX.shadowColor='#B8860B';CX.shadowBlur=8;
    CX.fillText('— CURSED MERCHANT —',W/2,WT+22);CX.shadowBlur=0;
    // Always-visible instruction
    CX.fillStyle='rgba(255,208,96,.55)';CX.font='10px Share Tech Mono,monospace';
    CX.fillText('WALK TO AN ITEM  ·  PRESS  E  TO BUY',W/2,WT+38);
    rm.shopItems.forEach((item,i)=>{
      const sx=W/2+((item.slot??i)-1)*210,sy=H/2;
      drawShopPedestal(item,sx,sy,i,t);
    });
    if(shopNearIdx>=0&&rm.shopItems[shopNearIdx]){
      const si=rm.shopItems[shopNearIdx];
      document.getElementById('shopPrompt').style.opacity='1';
      document.getElementById('shopPrompt').textContent=`[E] Buy ${si.nm} — ${si.cost} pts`;
    } else {
      document.getElementById('shopPrompt').style.opacity='0';
    }
    if(typeof updateEBuyBtn==='function') updateEBuyBtn();
  } else {
    document.getElementById('shopPrompt').style.opacity='0';
  }

  // Exit descent portal — shown in boss room after boss defeated
  if(rm._exitReady){
    const t2=Date.now()/1000;
    CX.save();CX.translate(W/2,H/2);

    // Outer glow rings
    for(let r=0;r<3;r++){
      const rad=55+r*20+Math.sin(t2*2+r)*5;
      const alpha=(.25-r*.07)+Math.sin(t2*1.5+r)*.05;
      CX.strokeStyle=`rgba(100,50,255,${alpha})`;
      CX.lineWidth=2-r*.4;
      CX.beginPath();CX.arc(0,0,rad,0,Math.PI*2);CX.stroke();
    }

    // Swirling void portal floor
    const spokes=12;
    for(let i=0;i<spokes;i++){
      const a=t2*.6+i*(Math.PI*2/spokes);
      const len=28+Math.sin(t2*2+i*.8)*8;
      CX.strokeStyle=`rgba(${80+i*5},${20+i*3},255,${.3+Math.sin(t2+i)*.15})`;
      CX.lineWidth=1.5;
      CX.beginPath();CX.moveTo(0,0);CX.lineTo(Math.cos(a)*len,Math.sin(a)*len);CX.stroke();
    }

    // Dark centre void
    const vg=CX.createRadialGradient(0,0,4,0,0,36);
    vg.addColorStop(0,'rgba(0,0,20,.95)');
    vg.addColorStop(.5,'rgba(30,10,80,.7)');
    vg.addColorStop(1,'transparent');
    CX.fillStyle=vg;CX.beginPath();CX.arc(0,0,36,0,Math.PI*2);CX.fill();

    // Ladder rungs descending into void
    CX.strokeStyle='rgba(150,100,255,.8)';CX.lineWidth=2;
    for(let r=0;r<4;r++){
      const ry=-10+r*7;const rw2=14-r*2;
      CX.beginPath();CX.moveTo(-rw2,ry);CX.lineTo(rw2,ry);CX.stroke();
    }
    // Ladder rails
    CX.strokeStyle='rgba(180,140,255,.6)';CX.lineWidth=1.5;
    CX.beginPath();CX.moveTo(-14,-10);CX.lineTo(-8,18);CX.stroke();
    CX.beginPath();CX.moveTo(14,-10);CX.lineTo(8,18);CX.stroke();

    // Pulsing label
    const pulse=.8+Math.sin(t2*3)*.2;
    CX.save();CX.scale(pulse,pulse);
    CX.fillStyle='rgba(5,3,10,.85)';
    CX.beginPath();CX.roundRect(-62,42,124,20,4);CX.fill();
    CX.fillStyle='#AA88FF';CX.font='bold 12px Creepster,cursive';
    CX.textAlign='center';CX.textBaseline='middle';
    CX.fillText('⬇ DESCEND TO NEXT FLOOR',0,52);
    CX.restore();

    // Arrow indicator pointing at portal
    CX.fillStyle=`rgba(180,140,255,${.5+Math.sin(t2*4)*.3})`;
    CX.beginPath();CX.moveTo(0,-52);CX.lineTo(-8,-44);CX.lineTo(8,-44);CX.closePath();CX.fill();

    CX.restore();
  }

  if(rm.type==='powerup'&&rm.cleared&&rm.puPending){
    CX.save();CX.translate(W/2,H/2+Math.sin(t*2)*6);
    CX.shadowColor='#8B0000';CX.shadowBlur=20+Math.sin(t*3)*8;
    CX.font='42px serif';CX.textAlign='center';CX.textBaseline='middle';CX.fillText('💎',0,0);
    for(let i=0;i<6;i++){
      const a=t*1.2+i*(Math.PI/3),r=32+Math.sin(t*2+i)*6;
      CX.fillStyle=`rgba(139,0,0,${.3+Math.sin(t+i)*.2})`;
      CX.beginPath();CX.arc(Math.cos(a)*r,Math.sin(a)*r,2,0,Math.PI*2);CX.fill();
    }
    CX.shadowBlur=0;CX.restore();
  }
}

function drawShopPedestal(item,sx,sy,idx,t){
  const near=(shopNearIdx===idx);
  const canAfford=score>=item.cost;
  CX.save();CX.translate(sx,sy);

  // Floor glow
  if(near){
    CX.save();
    const glow=CX.createRadialGradient(0,40,5,0,40,80);
    glow.addColorStop(0,canAfford?'rgba(184,134,11,.4)':'rgba(139,0,0,.35)');
    glow.addColorStop(1,'transparent');
    CX.fillStyle=glow;CX.beginPath();CX.ellipse(0,40,80,32,0,0,Math.PI*2);CX.fill();
    CX.restore();
  }

  // Card
  const cardH=near?220:185;
  CX.fillStyle=near?'#201830':'#160E24';
  CX.strokeStyle=near?(canAfford?'#DAA520':'#CC2222'):'rgba(184,134,11,.4)';
  CX.lineWidth=near?2:1;
  CX.shadowColor=near?(canAfford?'#B8860B':'#8B0000'):'transparent';
  CX.shadowBlur=near?16:0;
  CX.beginPath();CX.roundRect(-74,-95,148,cardH,6);CX.fill();CX.stroke();
  CX.shadowBlur=0;

  const bob=Math.sin(t*1.3+idx)*3;
  CX.translate(0,bob);

  // Icon — bigger
  CX.font='36px serif';CX.textAlign='center';CX.textBaseline='middle';
  CX.shadowColor=canAfford?'#B8860B':'#444';CX.shadowBlur=near?18:8;
  CX.fillText(item.ic,0,-38);CX.shadowBlur=0;

  // Name — bigger and always bold
  CX.fillStyle=near?'#FFE8A0':'#D8CFA8';
  CX.font='bold 15px Creepster,cursive';
  CX.textAlign='center';CX.textBaseline='middle';
  CX.fillText(item.nm,0,-4);

  // Game effect — green, always visible, clear gameplay text
  const gameText=item.game||'';
  CX.fillStyle=near?'#88FFAA':'#55CC77';
  CX.font='bold 11px Share Tech Mono,monospace';
  CX.fillText(gameText,0,14);

  // Divider
  CX.strokeStyle='rgba(184,134,11,.3)';CX.lineWidth=1;
  CX.beginPath();CX.moveTo(-50,24);CX.lineTo(50,24);CX.stroke();

  // Cost
  CX.fillStyle=canAfford?'#FFD060':'#FF5555';
  CX.font='bold 12px Share Tech Mono,monospace';
  CX.fillText(item.cost+' pts',0,36);

  // Security tip — clipped strictly inside card
  CX.save();
  // Clip relative to current transform (after bob translate)
  CX.beginPath();CX.rect(-68,-92,136,cardH-8);CX.clip();
  const tipText=(item.desc||'').replace('Real tip: ','').replace('Real tip:','');
  CX.fillStyle=near?'rgba(210,200,175,.88)':'rgba(170,160,135,.7)';
  CX.font='9px Share Tech Mono,monospace';
  const maxW=18;
  const tipWords=tipText.split(' ');
  let line='',lines=[];
  tipWords.forEach(w=>{if((line+' '+w).trim().length>maxW){lines.push(line.trim());line=w;}else line+=(line?' ':'')+w;});
  if(line.trim())lines.push(line.trim());
  lines.slice(0,5).forEach((l,li)=>CX.fillText(l,0,50+li*11));
  CX.restore();

  // E badge when near + can afford
  if(near&&canAfford&&shopEntryCooldown<=0){
    const pulse=.85+Math.sin(t*4)*.15;
    CX.save();CX.translate(0,-100);CX.scale(pulse,pulse);
    CX.fillStyle='#DAA520';CX.strokeStyle='#FFD060';CX.lineWidth=2;
    CX.beginPath();CX.roundRect(-16,-11,32,22,4);CX.fill();CX.stroke();
    CX.fillStyle='#0A0808';CX.font='bold 14px Creepster,cursive';
    CX.textAlign='center';CX.textBaseline='middle';CX.fillText('E',0,0);
    CX.restore();
  } else if(near&&!canAfford){
    CX.fillStyle='rgba(220,60,60,.9)';CX.font='bold 9px Share Tech Mono,monospace';
    CX.textAlign='center';CX.fillText('NEED MORE SOULS',0,-100);
  }

  CX.restore();
}

function drawRoomBanner(){
  if(roomBanner.alpha<=0) return;
  const t=Date.now()/1000;
  CX.save();
  CX.globalAlpha=Math.min(1,roomBanner.alpha);
  // Background
  const bh=72, by=H/2-bh/2;
  const g=CX.createLinearGradient(0,by,0,by+bh);
  g.addColorStop(0,'rgba(5,3,10,0)');
  g.addColorStop(.3,'rgba(5,3,10,.92)');
  g.addColorStop(.7,'rgba(5,3,10,.92)');
  g.addColorStop(1,'rgba(5,3,10,0)');
  CX.fillStyle=g;
  CX.fillRect(0,by,W,bh);
  // Main text
  CX.shadowColor='#8B0000';CX.shadowBlur=16;
  CX.font='bold 28px Creepster,cursive';
  CX.textAlign='center';CX.textBaseline='middle';
  CX.fillStyle='#C41E1E';
  CX.fillText(roomBanner.text,W/2,H/2-10);
  // Sub text
  CX.shadowColor='transparent';CX.shadowBlur=0;
  CX.font='13px Share Tech Mono,monospace';
  CX.fillStyle='rgba(200,191,168,.85)';
  CX.fillText(roomBanner.sub,W/2,H/2+16);
  CX.restore();
}

function fadeHUDPanels(){
  if(!player) return;
  // Right panel covers roughly x > W-200, y > H-320
  const inZone = player.x > W-210 && player.y > H-340;
  const op = inZone ? '0.15' : '1';
  const mm=document.getElementById('mmcv');
  const inv=document.getElementById('invPanel');
  if(mm) mm.style.opacity=op;
  if(inv) inv.style.opacity=op;
}

function drawMM(){
  const mm=document.getElementById('mmcv');
  const MW=mm.width||220, MH=mm.height||190;
  MC.clearRect(0,0,MW,MH);
  if(!dungeonGrid.length) return;
  MC.fillStyle='rgba(4,2,8,.97)'; MC.fillRect(0,0,MW,MH);

  // Title bar
  MC.fillStyle='#2A0A14'; MC.fillRect(0,0,MW,20);
  MC.fillStyle='#CC4444';
  MC.font='bold 11px monospace'; MC.textAlign='center'; MC.textBaseline='middle';
  MC.fillText('DUNGEON MAP', MW/2, 10);

  // Find bounding box of ALL placed rooms so layout never shifts as you explore
  let minGX=GW,maxGX=0,minGY=GH,maxGY=0;
  for(let gy=0;gy<GH;gy++) for(let gx=0;gx<GW;gx++){
    if(dungeonGrid[gy]?.[gx]){
      minGX=Math.min(minGX,gx); maxGX=Math.max(maxGX,gx);
      minGY=Math.min(minGY,gy); maxGY=Math.max(maxGY,gy);
    }
  }
  const spanX=maxGX-minGX+1, spanY=maxGY-minGY+1;

  // Calculate cell size to fill available space
  const pad=5, titleH=22, legH=22;
  const avW=MW-pad*2;
  const avH=MH-titleH-legH-pad*2;
  const cw=Math.floor(avW/spanX);
  const ch=Math.floor(avH/spanY);
  const rw=Math.max(cw-4, 6);  // room rect width
  const rh=Math.max(ch-4, 4);  // room rect height

  // Center grid in available space
  const ox=pad+Math.floor((avW-spanX*cw)/2);
  const oy=titleH+pad+Math.floor((avH-spanY*ch)/2);

  const RFILL={start:'#1A3A1A',combat:'#2A2640',boss:'#4A1010',shop:'#2A2010',powerup:'#102038'};
  const RBORD={start:'#1A6A1A',combat:'#252045',boss:'#CC2222',shop:'#B8860B',powerup:'#2277BB'};

  // Pass 1: corridor lines between connected visited rooms
  for(let gy=0;gy<GH;gy++){
    for(let gx=0;gx<GW;gx++){
      const rm=dungeonGrid[gy]?.[gx]; if(!rm) continue;
      const key=`${gx},${gy}`;
      const isCur=gx===roomPos.x&&gy===roomPos.y;
      if(!visited.has(key)&&!isCur) continue;
      // Local position of room centre in minimap pixels
      const lx=gx-minGX, ly=gy-minGY;
      const rcx=ox+lx*cw+2+rw/2;
      const rcy=oy+ly*ch+2+rh/2;
      MC.strokeStyle='#2A1840'; MC.lineWidth=3;
      if(rm.doors.R){
        const nkey=`${gx+1},${gy}`;
        const nr=dungeonGrid[gy]?.[gx+1];
        if(nr&&(visited.has(nkey)||(gx+1===roomPos.x&&gy===roomPos.y))){
          const nx2=ox+(gx+1-minGX)*cw+2+rw/2;
          MC.beginPath(); MC.moveTo(rcx,rcy); MC.lineTo(nx2,rcy); MC.stroke();
        }
      }
      if(rm.doors.D){
        const nkey=`${gx},${gy+1}`;
        const nr=dungeonGrid[gy+1]?.[gx];
        if(nr&&(visited.has(nkey)||(gx===roomPos.x&&gy+1===roomPos.y))){
          const ny2=oy+(gy+1-minGY)*ch+2+rh/2;
          MC.beginPath(); MC.moveTo(rcx,rcy); MC.lineTo(rcx,ny2); MC.stroke();
        }
      }
    }
  }

  // Pass 2: room boxes
  for(let gy=0;gy<GH;gy++){
    for(let gx=0;gx<GW;gx++){
      const rm=dungeonGrid[gy]?.[gx]; if(!rm) continue;
      const key=`${gx},${gy}`;
      const isCur=gx===roomPos.x&&gy===roomPos.y;
      if(!visited.has(key)&&!isCur) continue;
      const isClr=cleared.has(key);
      const lx=gx-minGX, ly=gy-minGY;
      const rx=ox+lx*cw+2, ry=oy+ly*ch+2;

      // Room fill
      MC.fillStyle=isCur?'#8A1010':(isClr?(RFILL[rm.type]||'#2A2640'):'#0E0C18');
      MC.fillRect(rx,ry,rw,rh);

      // Room border
      MC.strokeStyle=isCur?'#FF6666':(isClr?(RBORD[rm.type]||'#4A4880'):'#2A2640');
      MC.lineWidth=isCur?2:1;
      MC.strokeRect(rx,ry,rw,rh);

      // Door notches
      MC.fillStyle='rgba(4,2,8,.97)';
      const dg=Math.max(2,Math.round(Math.min(rw,rh)*.2));
      const dhx=Math.round(rw/2)-1, dhy=Math.round(rh/2)-1;
      if(rm.doors.U) MC.fillRect(rx+dhx,ry,dg,2);
      if(rm.doors.D) MC.fillRect(rx+dhx,ry+rh-2,dg,2);
      if(rm.doors.L) MC.fillRect(rx,ry+dhy,2,dg);
      if(rm.doors.R) MC.fillRect(rx+rw-2,ry+dhy,2,dg);

      // Room type icon
      const cx2=rx+rw/2, cy2=ry+rh/2;
      MC.textAlign='center'; MC.textBaseline='middle';
      const fsz=Math.max(9, Math.min(rw,rh)*.7);
      if(rm.type==='boss'){ MC.fillStyle='#FF5555'; MC.font=`bold ${fsz}px monospace`; MC.fillText('B',cx2,cy2); }
      else if(rm.type==='shop'){ MC.fillStyle='#DAA520'; MC.font=`bold ${fsz}px monospace`; MC.fillText('$',cx2,cy2); }
      else if(rm.type==='powerup'){ MC.fillStyle='#55AAFF'; MC.font=`${fsz}px monospace`; MC.fillText('\u2605',cx2,cy2); }
      else if(rm.type==='start'){ MC.fillStyle='#55AA55'; MC.font=`${fsz}px monospace`; MC.fillText('\u2302',cx2,cy2); }
      else if(!isClr){ MC.fillStyle='#CC3333'; MC.font=`bold ${fsz*.8}px monospace`; MC.fillText('!',cx2,cy2); }
    }
  }

  // Blinking player dot
  const t=Date.now()/1000;
  if(Math.sin(t*6)>0){
    const lx=roomPos.x-minGX, ly=roomPos.y-minGY;
    const prx=ox+lx*cw+2+rw/2;
    const pry=oy+ly*ch+2+rh/2;
    MC.fillStyle='#FFFFFF'; MC.shadowColor='#FFFFFF'; MC.shadowBlur=8;
    MC.beginPath(); MC.arc(prx,pry,4,0,Math.PI*2); MC.fill();
    MC.shadowBlur=0;
    // Small arrow showing direction
    MC.fillStyle='rgba(255,200,200,.8)';
    MC.beginPath(); MC.arc(prx,pry,4,0,Math.PI*2); MC.fill();
  }

  // Legend bar
  const legY=MH-legH;
  MC.fillStyle='#100810'; MC.fillRect(0,legY,MW,legH);
  MC.strokeStyle='#3A1828'; MC.lineWidth=1;
  MC.beginPath(); MC.moveTo(0,legY); MC.lineTo(MW,legY); MC.stroke();
  const leg=[
    {col:'#FF5555',lbl:'BOSS'},{col:'#DAA520',lbl:'SHOP'},
    {col:'#55AAFF',lbl:'RELIC'},{col:'#55AA55',lbl:'START'},{col:'#CC3333',lbl:'ENEMY'}
  ];
  const lw2=MW/leg.length;
  leg.forEach((l,i)=>{
    const lx2=Math.round(i*lw2+3);
    MC.fillStyle=l.col; MC.fillRect(lx2,legY+5,7,7);
    MC.fillStyle='#B8A898'; MC.font='bold 8px monospace';
    MC.textAlign='left'; MC.textBaseline='middle';
    MC.fillText(l.lbl, lx2+10, legY+9);
  });
}

// ── ENEMY DRAWING ─────────────────────────────────────────────
function drawEnemy(e){
  const t=Date.now()/1000;
  CX.save();CX.translate(e.x,e.y);
  CX.translate(0,Math.sin(t*2.1+e.phase)*2.5);
  if(e._flash>0){CX.globalAlpha=.55+e._flash*.45;e._flash=Math.max(0,e._flash-.12);}
  CX.shadowColor=e.col;CX.shadowBlur=e.boss?24:14;
  const s=e.sz;
  switch(e.shp){
    case 'envelope': drawEnvShape(s,e.col,t);break;
    case 'letter':   drawLetterShape(s,e.col,t);break;
    case 'agent':    drawAgentShape(s,e.col,t);break;
    case 'charmer':  drawCharmerShape(s,e.col,t);break;
    case 'address':  drawAddrShape(s,e.col,t);break;
    case 'dust':     drawDustShape(s,e.col,t);break;
    case 'boss_env': drawBossEnv(s,e.col,t);break;
    case 'boss_agent':drawBossAgent(s,e.col,t);break;
    case 'boss_dust':drawBossDust(s,e.col,t);break;
    default:CX.fillStyle=e.col;CX.beginPath();CX.arc(0,0,s,0,Math.PI*2);CX.fill();
  }
  CX.shadowBlur=0;
  if(e.boss)drawBossBar(e);
  // ── Enemy label — big, pill background, always readable ──
  CX.shadowBlur=0;
  const lblY = s + (e.boss ? 30 : 8);
  // Line 1: enemy name in Creepster
  const nameSize = e.boss ? 16 : 14;
  CX.font = `bold ${nameSize}px Creepster,cursive`;
  CX.textAlign='center'; CX.textBaseline='top';
  const nameW = CX.measureText(e.lbl).width + 14;
  // Dark pill behind name
  CX.fillStyle='rgba(4,2,8,.88)';
  CX.beginPath(); CX.roundRect(-nameW/2, lblY-2, nameW, nameSize+6, 4); CX.fill();
  // Coloured text
  CX.fillStyle = e.boss ? '#FFD060' : '#FFFFFF';
  CX.fillText(e.lbl, 0, lblY);
  // Line 2: plain English scam type — always shown, not just on hover
  if(!e.boss){
    const hint = SCAM_HINTS[e.type] || '';
    if(hint){
      const hintSize = 11;
      CX.font = `${hintSize}px Share Tech Mono,monospace`;
      const hintW = CX.measureText(hint).width + 12;
      const hintY = lblY + nameSize + 5;
      CX.fillStyle='rgba(4,2,8,.82)';
      CX.beginPath(); CX.roundRect(-hintW/2, hintY-2, hintW, hintSize+5, 3); CX.fill();
      CX.fillStyle = e.col;
      CX.fillText(hint, 0, hintY);
    }
  }
  CX.restore();
}

function drawEnvShape(s,col,t){
  CX.fillStyle=col;
  CX.beginPath();CX.moveTo(-s,-s*.7);CX.lineTo(s,-s*.7);CX.lineTo(s,s*.7);CX.lineTo(-s,s*.7);CX.closePath();CX.fill();
  CX.fillStyle=darken(col,.35);CX.beginPath();CX.moveTo(-s,-s*.7);CX.lineTo(s,-s*.7);CX.lineTo(0,s*.05);CX.closePath();CX.fill();
  for(let i=0;i<3;i++){
    const d=((t*.3+i*.35)%1);CX.fillStyle=col+'99';
    CX.beginPath();CX.ellipse(-s*.5+i*s*.5,s*.7+d*14,2,5+d*7,0,0,Math.PI*2);CX.fill();
  }
  const ep=Math.abs(Math.sin(t*2.8));
  CX.fillStyle='#FF0000';CX.shadowColor='#FF0000';CX.shadowBlur=10*ep;
  CX.beginPath();CX.ellipse(0,s*.05,s*.22,s*.14*(ep+.1),0,0,Math.PI*2);CX.fill();
  CX.fillStyle='#000';CX.beginPath();CX.ellipse(0,s*.05,s*.08,s*.06*(ep+.1),0,0,Math.PI*2);CX.fill();
  CX.shadowBlur=14;CX.fillStyle='rgba(0,0,0,.7)';CX.font=`bold ${s*.5}px monospace`;
  CX.textAlign='center';CX.textBaseline='middle';CX.fillText('@',0,s*.5);
}

function drawLetterShape(s,col,t){
  CX.fillStyle='#DDD8C0';CX.strokeStyle=col+'AA';CX.lineWidth=1.5;
  CX.beginPath();CX.roundRect(-s,-s*.95,s*2,s*1.9,3);CX.fill();CX.stroke();
  CX.strokeStyle='rgba(0,0,0,.12)';CX.lineWidth=.6;
  for(let i=0;i<4;i++){CX.beginPath();CX.moveTo(-s+5,-s*.5+i*s*.3);CX.lineTo(s-5,-s*.5+i*s*.3);CX.stroke();}
  CX.save();CX.rotate(-.3);CX.strokeStyle=col;CX.lineWidth=2.5;
  CX.font=`bold ${s*.48}px Creepster,cursive`;CX.textAlign='center';CX.textBaseline='middle';CX.strokeText('SCAM',0,0);CX.restore();
  CX.fillStyle=col+'55';CX.font=`${s*.7}px serif`;CX.textAlign='center';CX.textBaseline='middle';CX.fillText('☠',0,s*.55);
}

function drawAgentShape(s,col,t){
  CX.fillStyle=col;
  CX.beginPath();CX.arc(0,-s*.28,s*.58,0,Math.PI*2);CX.fill();
  CX.beginPath();CX.moveTo(-s*.7,s*.95);CX.quadraticCurveTo(0,s*.2,s*.7,s*.95);CX.fill();
  CX.fillStyle=darken(col,.4);CX.beginPath();CX.moveTo(-s*.2,s*.1);CX.lineTo(0,s*.5);CX.lineTo(s*.2,s*.1);CX.closePath();CX.fill();
  CX.strokeStyle=darken(col,.3);CX.lineWidth=3.5;CX.beginPath();CX.arc(0,-s*.42,s*.72,Math.PI,Math.PI*2);CX.stroke();
  CX.fillStyle=darken(col,.25);CX.beginPath();CX.arc(-s*.72,-s*.42,s*.18,0,Math.PI*2);CX.fill();
  CX.beginPath();CX.arc(s*.72,-s*.42,s*.18,0,Math.PI*2);CX.fill();
  const drawX=(ex,ey)=>{CX.strokeStyle='#000';CX.lineWidth=1.8;
    CX.beginPath();CX.moveTo(ex-4,ey-4);CX.lineTo(ex+4,ey+4);CX.stroke();
    CX.beginPath();CX.moveTo(ex+4,ey-4);CX.lineTo(ex-4,ey+4);CX.stroke();};
  drawX(-s*.2,-s*.32);drawX(s*.2,-s*.32);
  CX.strokeStyle='#000';CX.lineWidth=1.8;CX.beginPath();CX.arc(0,-s*.12,s*.25,.1,Math.PI-.1);CX.stroke();
  for(let i=0;i<4;i++){CX.fillStyle='rgba(240,230,210,.85)';CX.fillRect(-s*.2+i*s*.12,-s*.04,s*.1,s*.09);}
}

function drawCharmerShape(s,col,t){
  CX.fillStyle=col;
  CX.beginPath();CX.arc(0,-s*.38,s*.55,0,Math.PI*2);CX.fill();
  CX.beginPath();CX.moveTo(-s*.7,s*.9);CX.quadraticCurveTo(0,s*.15,s*.7,s*.9);CX.fill();
  CX.fillStyle='rgba(0,0,0,.6)';CX.beginPath();CX.roundRect(-s*.58,s*.25,s*1.16,s*.42,3);CX.fill();
  CX.fillStyle='#DDD8C0';CX.font=`${s*.27}px Special Elite,cursive`;CX.textAlign='center';CX.textBaseline='middle';CX.fillText('TRUST ME',0,s*.46);
  const wink=Math.sin(t*1.4)>.75;
  CX.fillStyle='#FF000099';CX.shadowColor='#FF0000';CX.shadowBlur=5;
  if(wink){CX.strokeStyle='#FF000099';CX.lineWidth=1.5;CX.beginPath();CX.moveTo(-s*.2,-s*.42);CX.lineTo(-s*.1,-s*.42);CX.stroke();}
  else{CX.beginPath();CX.arc(-s*.15,-s*.42,s*.1,0,Math.PI*2);CX.fill();}
  CX.beginPath();CX.arc(s*.15,-s*.42,s*.1,0,Math.PI*2);CX.fill();CX.shadowBlur=14;
  CX.strokeStyle='#000';CX.lineWidth=1.8;CX.beginPath();CX.arc(0,-s*.2,s*.32,0.05,Math.PI-.05);CX.stroke();
}

function drawAddrShape(s,col,t){
  CX.fillStyle='#0A080F';CX.strokeStyle=col;CX.lineWidth=1.5;
  CX.beginPath();CX.roundRect(-s,-s,s*2,s*1.75,3);CX.fill();CX.stroke();
  CX.font=`${s*.28}px Share Tech Mono,monospace`;CX.textAlign='left';
  const rows=['0x4f3b...','...d8a2','...FAKE','...c91f'];
  const cols=[col,col,'#FF2222',col];
  for(let i=0;i<4;i++){CX.fillStyle=cols[i];CX.fillText(rows[i],-s+4,-s*.65+i*s*.38);}
  if(Math.floor(t*2)%2===0){CX.fillStyle='#FF2222';CX.fillRect(-s+4,-s*.65-2,CX.measureText('0x4f3b...').width+2,s*.3);}
  CX.fillStyle=col+'60';CX.font=`${s*.7}px serif`;CX.textAlign='center';CX.textBaseline='bottom';CX.fillText('☠',0,s*.8);
}

function drawDustShape(s,col,t){
  CX.save();CX.rotate(t*.9);
  CX.beginPath();for(let i=0;i<6;i++){const a=(Math.PI/3)*i;i===0?CX.moveTo(Math.cos(a)*s,Math.sin(a)*s):CX.lineTo(Math.cos(a)*s,Math.sin(a)*s);}
  CX.closePath();CX.fillStyle=col;CX.fill();CX.restore();
  CX.save();CX.rotate(-t*.6);
  CX.beginPath();for(let i=0;i<6;i++){const a=(Math.PI/3)*i+.5;i===0?CX.moveTo(Math.cos(a)*s*.6,Math.sin(a)*s*.6):CX.lineTo(Math.cos(a)*s*.6,Math.sin(a)*s*.6);}
  CX.closePath();CX.fillStyle=darken(col,.3);CX.fill();CX.restore();
  const ep=Math.abs(Math.sin(t*4));
  CX.fillStyle='#FF0000';CX.shadowColor='#FF0000';CX.shadowBlur=10*ep;
  CX.beginPath();CX.arc(0,0,s*.3,0,Math.PI*2);CX.fill();CX.shadowBlur=14;
  CX.fillStyle='#000';CX.font=`bold ${s*.45}px monospace`;CX.textAlign='center';CX.textBaseline='middle';CX.fillText('$',0,0);
}

function drawBossEnv(s,col,t){
  CX.fillStyle=col;CX.beginPath();CX.moveTo(-s,-s*.8);CX.lineTo(0,s*.55);CX.lineTo(s,-s*.8);CX.lineTo(s,s*.85);CX.lineTo(-s,s*.85);CX.closePath();CX.fill();
  for(let i=0;i<6;i++){const d=((t*.35+i*.18)%1);CX.fillStyle=col+'AA';CX.beginPath();CX.ellipse(-s*.6+i*s*.24,s*.85+d*22,3,6+d*9,0,0,Math.PI*2);CX.fill();}
  CX.fillStyle=darken(col,.2);CX.beginPath();CX.moveTo(-s,-s*.8);CX.lineTo(s,-s*.8);CX.lineTo(0,s*.1);CX.closePath();CX.fill();
  const ep=Math.abs(Math.sin(t*1.8));
  CX.fillStyle='#FF0000';CX.shadowColor='#FF0000';CX.shadowBlur=20*ep;
  CX.beginPath();CX.ellipse(0,s*.1,s*.28,s*.2*(ep+.08),0,0,Math.PI*2);CX.fill();
  CX.fillStyle='#000';CX.beginPath();CX.ellipse(0,s*.1,s*.12,s*.1*(ep+.08),0,0,Math.PI*2);CX.fill();
  CX.shadowBlur=24;CX.fillStyle=col+'50';CX.font=`bold ${s*.38}px Share Tech Mono,monospace`;CX.textAlign='center';CX.textBaseline='middle';CX.fillText('PHISH',0,s*.6);
}

function drawBossAgent(s,col,t){
  CX.fillStyle=col;CX.beginPath();CX.arc(0,-s*.22,s*.68,0,Math.PI*2);CX.fill();
  CX.beginPath();CX.moveTo(-s*.85,s*.95);CX.quadraticCurveTo(0,s*.22,s*.85,s*.95);CX.fill();
  CX.strokeStyle=darken(col,.25);CX.lineWidth=6;CX.beginPath();CX.arc(0,-s*.42,s*.85,Math.PI,Math.PI*2);CX.stroke();
  [[-s*.85,-s*.42],[s*.85,-s*.42]].forEach(([ex,ey])=>{CX.fillStyle=darken(col,.3);CX.beginPath();CX.arc(ex,ey,s*.28,0,Math.PI*2);CX.fill();});
  [[-s*.22,-s*.28],[s*.22,-s*.28]].forEach(([ex,ey])=>{
    CX.fillStyle='#FFFF44';CX.beginPath();CX.arc(ex,ey,s*.16,0,Math.PI*2);CX.fill();
    CX.strokeStyle='#000';CX.lineWidth=1.2;CX.save();CX.translate(ex,ey);CX.rotate(t*2.5);
    CX.beginPath();for(let a=0;a<Math.PI*5;a+=.15){const r=a*.022*s*.1;CX.lineTo(Math.cos(a)*r,Math.sin(a)*r);}CX.stroke();CX.restore();
  });
  CX.fillStyle='#000';CX.beginPath();CX.arc(0,-s*.02,s*.35,0,Math.PI);CX.fill();
  CX.fillStyle='rgba(240,230,210,.9)';
  for(let i=0;i<6;i++) CX.fillRect(-s*.28+i*s*.1,-s*.02,s*.08,s*.12);
}

function drawBossDust(s,col,t){
  for(let r=0;r<3;r++){
    CX.save();CX.rotate(t*(.6-r*.2)*(r%2?1:-1));
    const rs=s*(1-.2*r);CX.beginPath();
    for(let i=0;i<6;i++){const a=(Math.PI/3)*i+r*.5;i===0?CX.moveTo(Math.cos(a)*rs,Math.sin(a)*rs):CX.lineTo(Math.cos(a)*rs,Math.sin(a)*rs);}
    CX.closePath();CX.fillStyle=r===0?col:r===1?darken(col,.3):darken(col,.5);CX.globalAlpha=.9-r*.15;CX.fill();CX.restore();
  }
  CX.globalAlpha=1;
  const ep=Math.abs(Math.sin(t*2.8));
  CX.fillStyle='#FF0000';CX.shadowColor='#FF0000';CX.shadowBlur=22*ep;
  CX.beginPath();CX.arc(0,0,s*.33,0,Math.PI*2);CX.fill();
  CX.fillStyle='#000';CX.font=`bold ${s*.36}px serif`;CX.textAlign='center';CX.textBaseline='middle';CX.fillText('☠',0,0);
  CX.shadowBlur=24;
  for(let i=0;i<8;i++){const a=t*1.4+i*(Math.PI/4);CX.fillStyle=col+'BB';CX.beginPath();CX.arc(Math.cos(a)*s*1.35,Math.sin(a)*s*1.35,3,0,Math.PI*2);CX.fill();}
}

function drawBossBar(e){
  const bw=e.sz*3,bh=7,bx=-bw/2,by=e.sz+16;
  CX.fillStyle='#0A0808';CX.fillRect(bx,by,bw,bh);
  const pct=e.hp/e.maxHp;
  CX.fillStyle=pct>.5?e.col:pct>.25?'#AA5500':'#FF0000';CX.fillRect(bx,by,bw*pct,bh);
  CX.strokeStyle='#1A1020';CX.lineWidth=.5;CX.strokeRect(bx,by,bw,bh);
}

// ── Creepy doll drawing ──────────────────────────────────────
function drawDoll(ctx, s, kind, t){
  const boy = kind==='boy';
  // Shadow
  ctx.save();ctx.globalAlpha=.22;ctx.fillStyle='#000';
  ctx.beginPath();ctx.ellipse(0,s*.95,s*.55,s*.18,0,0,Math.PI*2);ctx.fill();
  ctx.globalAlpha=1;ctx.restore();

  // Legs / lower body
  if(boy){
    ctx.fillStyle='#1A1A3A';ctx.strokeStyle='#2A2A55';ctx.lineWidth=1;
    ctx.beginPath();ctx.roundRect(-s*.44,s*.32,s*.88,s*.46,2);ctx.fill();ctx.stroke();
    ctx.strokeStyle='#EDD8C0';ctx.lineWidth=s*.22;ctx.lineCap='round';
    ctx.beginPath();ctx.moveTo(-s*.22,s*.74);ctx.lineTo(-s*.24,s*.96);ctx.stroke();
    ctx.beginPath();ctx.moveTo(s*.22,s*.74);ctx.lineTo(s*.24,s*.96);ctx.stroke();
    ctx.fillStyle='#100808';
    ctx.beginPath();ctx.ellipse(-s*.25,s*.99,s*.18,s*.09,-.15,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.ellipse(s*.25,s*.99,s*.18,s*.09,.15,0,Math.PI*2);ctx.fill();
  } else {
    ctx.fillStyle='#2A0A2A';ctx.strokeStyle='#3A143A';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(-s*.36,s*.32);ctx.lineTo(-s*.66,s*.94);ctx.lineTo(s*.66,s*.94);ctx.lineTo(s*.36,s*.32);ctx.closePath();ctx.fill();ctx.stroke();
    ctx.strokeStyle='#4A1A4A';ctx.lineWidth=1.5;
    ctx.beginPath();ctx.moveTo(-s*.66,s*.94);ctx.lineTo(s*.66,s*.94);ctx.stroke();
    for(let i=0;i<8;i++){
      const lx=-s*.62+i*s*.18;
      ctx.beginPath();ctx.arc(lx,s*.94,s*.07,Math.PI,0);ctx.stroke();
    }
    ctx.strokeStyle='#EDD8C0';ctx.lineWidth=s*.18;ctx.lineCap='round';
    ctx.beginPath();ctx.moveTo(-s*.18,s*.88);ctx.lineTo(-s*.2,s*.98);ctx.stroke();
    ctx.beginPath();ctx.moveTo(s*.18,s*.88);ctx.lineTo(s*.2,s*.98);ctx.stroke();
  }

  // Torso
  ctx.fillStyle=boy?'#1A3A1A':'#2A0A2A';
  ctx.strokeStyle=boy?'#2A5A2A':'#3A143A';ctx.lineWidth=1;
  ctx.beginPath();ctx.roundRect(-s*.43,-s*.06,s*.86,s*.42,3);ctx.fill();ctx.stroke();

  // Arms
  ctx.strokeStyle='#EDD8C0';ctx.lineWidth=s*.2;ctx.lineCap='round';
  ctx.beginPath();ctx.moveTo(-s*.43,s*.1);ctx.lineTo(-s*.76,s*.36);ctx.stroke();
  ctx.beginPath();ctx.moveTo(s*.43,s*.1);ctx.lineTo(s*.72,s*.04);ctx.stroke();

  // Ledger device in right hand
  ctx.save();ctx.translate(s*.8,s*.0);ctx.rotate(-.28);
  ctx.shadowColor='#B8860B';ctx.shadowBlur=8;
  ctx.fillStyle='#1A1228';ctx.strokeStyle='#B8860B';ctx.lineWidth=1.5;
  ctx.beginPath();ctx.roundRect(-s*.22,-s*.3,s*.44,s*.6,2);ctx.fill();ctx.stroke();
  ctx.fillStyle='#8B6000AA';ctx.beginPath();ctx.roundRect(-s*.14,-s*.24,s*.28,s*.24,1);ctx.fill();
  ctx.fillStyle='#DAA520';ctx.font=(s*.17)+'px serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('\uD83D\uDD12',0,-s*.12);
  ctx.fillStyle='#B8860B';
  ctx.beginPath();ctx.roundRect(-s*.17,s*.08,s*.14,s*.08,1);ctx.fill();
  ctx.beginPath();ctx.roundRect(s*.03,s*.08,s*.14,s*.08,1);ctx.fill();
  ctx.shadowBlur=0;ctx.restore();

  // Neck
  ctx.fillStyle='#EDD8C0';
  ctx.beginPath();ctx.roundRect(-s*.14,-s*.22,s*.28,s*.2,2);ctx.fill();

  // Head
  if(boy){
    ctx.fillStyle='#EDD8C0';ctx.strokeStyle='#C8A882';ctx.lineWidth=1;
    ctx.beginPath();ctx.ellipse(0,-s*.62,s*.42,s*.5,0,0,Math.PI*2);ctx.fill();ctx.stroke();
  } else {
    ctx.fillStyle='#F0E8E0';ctx.strokeStyle='#C8B8A0';ctx.lineWidth=1;
    ctx.beginPath();
    ctx.moveTo(0,-s*1.1);ctx.lineTo(s*.38,-s*.76);ctx.lineTo(s*.42,-s*.46);
    ctx.lineTo(s*.3,-s*.15);ctx.lineTo(0,-s*.1);ctx.lineTo(-s*.3,-s*.15);
    ctx.lineTo(-s*.42,-s*.46);ctx.lineTo(-s*.38,-s*.76);ctx.closePath();
    ctx.fill();ctx.stroke();
    // porcelain crack
    ctx.strokeStyle='#8B6050';ctx.lineWidth=.8;
    ctx.beginPath();ctx.moveTo(s*.1,-s*.86);ctx.lineTo(s*.18,-s*.6);ctx.lineTo(s*.12,-s*.4);ctx.stroke();
  }

  // Hair
  if(boy){
    ctx.fillStyle='#1A1010';
    ctx.beginPath();ctx.ellipse(0,-s*1.07,s*.4,s*.22,0,Math.PI,0);ctx.fill();
    ctx.strokeStyle='#1A1010';ctx.lineWidth=2;ctx.lineCap='round';
    for(let i=-2;i<=2;i++){
      ctx.beginPath();ctx.moveTo(i*s*.1,-s*.99);ctx.lineTo(i*s*.12+s*.04,-s*1.14+Math.abs(i)*s*.03);ctx.stroke();
    }
  } else {
    ctx.fillStyle='#100808';
    ctx.beginPath();ctx.ellipse(0,-s*1.06,s*.44,s*.25,0,Math.PI,0);ctx.fill();
    ctx.strokeStyle='#100808';ctx.lineWidth=s*.14;ctx.lineCap='round';
    ctx.beginPath();ctx.moveTo(-s*.38,-s*.82);ctx.quadraticCurveTo(-s*.56,-s*.5,-s*.44,-s*.16);ctx.stroke();
    ctx.beginPath();ctx.moveTo(s*.38,-s*.82);ctx.quadraticCurveTo(s*.56,-s*.5,s*.44,-s*.16);ctx.stroke();
    // bow
    ctx.fillStyle='#8B0000';
    ctx.beginPath();ctx.moveTo(-s*.18,-s*1.09);ctx.lineTo(-s*.02,-s*.99);ctx.lineTo(-s*.18,-s*.93);ctx.closePath();ctx.fill();
    ctx.beginPath();ctx.moveTo(s*.18,-s*1.09);ctx.lineTo(s*.02,-s*.99);ctx.lineTo(s*.18,-s*.93);ctx.closePath();ctx.fill();
    ctx.fillStyle='#AA1111';ctx.beginPath();ctx.arc(0,-s*.99,s*.07,0,Math.PI*2);ctx.fill();
  }

  // Button eyes
  const eyeY=boy?-s*.64:-s*.58;
  const eyeX=s*.16;
  // whites
  ctx.fillStyle='#EEE8D8';
  ctx.beginPath();ctx.ellipse(-eyeX,eyeY,s*.11,s*.11,0,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.ellipse(eyeX,eyeY,s*.11,s*.11,0,0,Math.PI*2);ctx.fill();
  // button function
  const btn=(bx,by)=>{
    ctx.fillStyle='#0A0808';ctx.beginPath();ctx.arc(bx,by,s*.075,0,Math.PI*2);ctx.fill();
    ctx.strokeStyle='#3A2020';ctx.lineWidth=.8;
    ctx.beginPath();ctx.moveTo(bx-s*.04,by);ctx.lineTo(bx+s*.04,by);ctx.stroke();
    ctx.beginPath();ctx.moveTo(bx,by-s*.04);ctx.lineTo(bx,by+s*.04);ctx.stroke();
    ctx.fillStyle='#5A3030';
    ctx.beginPath();ctx.arc(bx-s*.025,by-s*.025,s*.018,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(bx+s*.025,by+s*.025,s*.018,0,Math.PI*2);ctx.fill();
  };
  btn(-eyeX,eyeY);btn(eyeX,eyeY);

  // Mouth
  if(boy){
    ctx.strokeStyle='#1A0808';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(-s*.18,-s*.42);ctx.lineTo(s*.18,-s*.42);ctx.stroke();
    for(let i=-2;i<=2;i++){
      ctx.beginPath();ctx.moveTo(i*s*.09,-s*.46);ctx.lineTo(i*s*.09,-s*.38);ctx.stroke();
    }
  } else {
    ctx.strokeStyle='#8B0000';ctx.lineWidth=1.5;
    ctx.beginPath();ctx.arc(0,-s*.39,s*.2,.2,Math.PI-.2);ctx.stroke();
    ctx.fillStyle='#8B0000';
    ctx.beginPath();ctx.arc(-s*.15,-s*.37,s*.03,0,Math.PI*2);ctx.fill();
    ctx.beginPath();ctx.arc(s*.12,-s*.35,s*.025,0,Math.PI*2);ctx.fill();
  }

  // Rosy cheeks
  ctx.globalAlpha=.22;
  ctx.fillStyle=boy?'#AA4433':'#CC5566';
  ctx.beginPath();ctx.ellipse(-s*.28,eyeY+s*.1,s*.1,s*.07,0,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.ellipse(s*.28,eyeY+s*.1,s*.1,s*.07,0,0,Math.PI*2);ctx.fill();
  ctx.globalAlpha=1;

  // Stitches across waist
  ctx.strokeStyle='#3A1818';ctx.lineWidth=1;ctx.setLineDash([2,3]);
  ctx.beginPath();ctx.moveTo(-s*.43,s*.18);ctx.lineTo(s*.43,s*.18);ctx.stroke();
  ctx.setLineDash([]);
}

function drawPlayer(p){
  if(iframes>0&&Math.floor(Date.now()/65)%2===0) return;
  CX.save();CX.translate(p.x,p.y); // no rotation — doll always faces up
  const s=p.size;
  CX.shadowColor='#8B0000';CX.shadowBlur=14;
  drawDoll(CX,s,selectedChar,Date.now()/1000);
  CX.restore();
}
function drawBullet(b){
  CX.save();CX.translate(b.x,b.y);
  if(!b.enemy){
    CX.rotate(Math.atan2(b.vy,b.vx));CX.shadowColor='#DAA520';CX.shadowBlur=10;CX.fillStyle='#FFD060';
    CX.beginPath();CX.moveTo(9,0);CX.lineTo(-6,4);CX.lineTo(-6,-4);CX.closePath();CX.fill();
  } else {
    CX.shadowColor=b.col||'#CC1111';CX.shadowBlur=12;
    const g=CX.createRadialGradient(0,0,1,0,0,7);
    g.addColorStop(0,b.col||'#FF3333');g.addColorStop(1,(b.col||'#CC1111')+'44');
    CX.fillStyle=g;CX.beginPath();CX.arc(0,0,6,0,Math.PI*2);CX.fill();
  }
  CX.shadowBlur=0;CX.restore();
}

function drawParticle(p){
  CX.save();CX.globalAlpha=p.life/p.maxLife;CX.fillStyle=p.color;CX.shadowColor=p.color;CX.shadowBlur=5;
  CX.beginPath();CX.arc(p.x,p.y,p.sz*(p.life/p.maxLife),0,Math.PI*2);CX.fill();CX.shadowBlur=0;CX.restore();
}

function drawDrop(d){
  const t=Date.now()/1000;
  const bob=Math.sin(t*2.5)*4;
  CX.save();CX.translate(d.x,d.y+bob);

  if(d.type==='relic'){
    // ── BOSS RELIC DROP: spinning golden diamond ──
    const pulse=.9+Math.sin(t*4)*.1;
    CX.save();CX.scale(pulse,pulse);CX.rotate(t*1.2);
    CX.shadowColor='#FFD060';CX.shadowBlur=22+Math.sin(t*3)*8;
    // Diamond shape
    CX.fillStyle='#DAA520';CX.strokeStyle='#FFD060';CX.lineWidth=2;
    CX.beginPath();CX.moveTo(0,-18);CX.lineTo(13,0);CX.lineTo(0,18);CX.lineTo(-13,0);CX.closePath();
    CX.fill();CX.stroke();
    CX.fillStyle='#FFE080';
    CX.beginPath();CX.moveTo(0,-18);CX.lineTo(6,0);CX.lineTo(0,18);CX.lineTo(-6,0);CX.closePath();
    CX.fill();
    CX.restore();CX.shadowBlur=0;
    // Label
    CX.font='bold 11px Creepster,cursive';CX.textAlign='center';CX.textBaseline='bottom';
    CX.fillStyle='rgba(4,2,8,.9)';
    const lwr=CX.measureText('RELIC').width+12;
    CX.beginPath();CX.roundRect(-lwr/2,-28,lwr,15,3);CX.fill();
    CX.fillStyle='#FFD060';CX.fillText('RELIC',0,-14);

  } else if(d.type==='hp'){
    // ── HEALTH DROP: GREEN heart / cross ──
    CX.shadowColor='#2ECC71';CX.shadowBlur=18+Math.sin(t*3)*6;
    // Green glow bg
    const bg=CX.createRadialGradient(0,0,2,0,0,18);
    bg.addColorStop(0,'rgba(46,204,113,.4)');bg.addColorStop(1,'transparent');
    CX.fillStyle=bg;CX.beginPath();CX.arc(0,0,18,0,Math.PI*2);CX.fill();
    // Green cross
    CX.fillStyle='#2ECC71';CX.strokeStyle='#1A8A3A';CX.lineWidth=1;
    CX.beginPath();CX.roundRect(-4,-13,8,26,2);CX.fill();CX.stroke();
    CX.beginPath();CX.roundRect(-13,-4,26,8,2);CX.fill();CX.stroke();
    CX.shadowBlur=0;
    // Label above
    CX.font='bold 11px Creepster,cursive';CX.textAlign='center';CX.textBaseline='bottom';
    CX.fillStyle='rgba(4,2,8,.85)';
    const lw1=CX.measureText('+ HEALTH').width+10;
    CX.beginPath();CX.roundRect(-lw1/2,-24,lw1,14,3);CX.fill();
    CX.fillStyle='#2ECC71';CX.fillText('+ HEALTH',0,-11);

  } else {
    // ── SCORE DROP: GOLD COIN — points/currency ──
    CX.shadowColor='#FFD060';CX.shadowBlur=16+Math.sin(t*3)*5;
    // Coin body
    CX.fillStyle='#DAA520';CX.strokeStyle='#FFD060';CX.lineWidth=2;
    CX.beginPath();CX.arc(0,0,13,0,Math.PI*2);CX.fill();CX.stroke();
    CX.fillStyle='#B8860B';
    CX.beginPath();CX.arc(0,0,9,0,Math.PI*2);CX.fill();
    // $ symbol
    CX.fillStyle='#FFD060';CX.font='bold 13px Creepster,cursive';
    CX.textAlign='center';CX.textBaseline='middle';CX.fillText('$',0,1);
    CX.shadowBlur=0;
    // Label above
    CX.font='bold 11px Creepster,cursive';CX.textAlign='center';CX.textBaseline='bottom';
    CX.fillStyle='rgba(4,2,8,.85)';
    const lw2=CX.measureText('+ SOULS').width+10;
    CX.beginPath();CX.roundRect(-lw2/2,-24,lw2,14,3);CX.fill();
    CX.fillStyle='#FFD060';CX.fillText('+ SOULS',0,-11);
  }

  CX.restore();
}

// ── GAME LOOP ─────────────────────────────────────────────────
function loop(ts){
  const dt=Math.min((ts-lastTS)/16.67,3);lastTS=ts;
  requestAnimationFrame(loop);
  if(gState==='playing') update(dt);
  if(gState!=='paused') drawScene();
}

// ── UPDATE ────────────────────────────────────────────────────
function update(dt){
  if(!player||gState!=='playing')return;
  const p=player;
  let dx=0,dy=0;
  if(pressed['ArrowLeft']||pressed['a']||pressed['A']) dx-=1;
  if(pressed['ArrowRight']||pressed['d']||pressed['D']) dx+=1;
  if(pressed['ArrowUp']||pressed['w']||pressed['W']) dy-=1;
  if(pressed['ArrowDown']||pressed['s']||pressed['S']) dy+=1;
  // Virtual joystick input
  if(typeof joy!=='undefined'&&joy.active){dx+=joy.dx;dy+=joy.dy;}
  if(dx||dy){const dl=Math.hypot(dx,dy);if(dl>1){dx/=dl;dy/=dl;}}
  const rm0=curRoom();
  const hw0=DHW+12;
  const inHDoor=Math.abs(p.x-W/2)<hw0;
  const inVDoor=Math.abs(p.y-H/2)<hw0;
  const minX=(rm0.doors.L&&rm0.cleared&&inVDoor)?PX1-WT*1.5:PX1+p.size;
  const maxX=(rm0.doors.R&&rm0.cleared&&inVDoor)?PX2+WT*1.5:PX2-p.size;
  const minY=(rm0.doors.U&&rm0.cleared&&inHDoor)?PY1-WT*1.5:PY1+p.size;
  const maxY=(rm0.doors.D&&rm0.cleared&&inHDoor)?PY2+WT*1.5:PY2-p.size;
  p.x=clamp(p.x+dx*pStats.spd*dt,minX,maxX);
  p.y=clamp(p.y+dy*pStats.spd*dt,minY,maxY);

  for(const o of curRoom().obstacles){
    const ol=o.x-o.w/2,or=o.x+o.w/2,ot=o.y-o.h/2,ob=o.y+o.h/2;
    if(p.x>ol-p.size&&p.x<or+p.size&&p.y>ot-p.size&&p.y<ob+p.size){
      const d=[ol-p.size-p.x,or+p.size-p.x,ot-p.size-p.y,ob+p.size-p.y];
      const mi=d.reduce((bi,v,i)=>Math.abs(v)<Math.abs(d[bi])?i:bi,0);
      if(mi===0)p.x=ol-p.size;else if(mi===1)p.x=or+p.size;else if(mi===2)p.y=ot-p.size;else p.y=ob+p.size;
    }
  }

  // ── GAMEPAD INPUT ──
  pollGamepad(p, dt);

  // ── AUTO-AIM: face & shoot nearest enemy ──
  shootCD=Math.max(0,shootCD-dt);

  // Find nearest enemy for aiming (null if room empty)
  let nearest=null, nearDist=Infinity;
  enemies.forEach(e=>{
    const d=Math.hypot(e.x-p.x,e.y-p.y);
    if(d<nearDist){nearDist=d;nearest=e;}
  });

  // Character faces movement direction only — bullets fire toward enemy independently
  if(dx!==0||dy!==0){
    p.angle=Math.atan2(dy,dx)+Math.PI/2;
  }
  // (angle stays at last movement direction when still)

  // Space/click fires always — even in empty rooms, respects all powerups
  if((pressed['_shoot']||pressed[' '])&&shootCD<=0){
    if(nearest){
      autoFireAt(nearest); // uses tri/bookmark powerups
    } else {
      // No enemy — fire facing direction with all powerups applied
      const a=p.angle-Math.PI/2;
      const spd=9;
      const fire=ang=>bullets.push({x:p.x,y:p.y,vx:Math.cos(ang)*spd,vy:Math.sin(ang)*spd,enemy:false});
      fire(a);
      if(pStats.tri){fire(a-.26);fire(a+.26);}
      if(hasPU('bookmark')) fire(a+.52);
    }
    shootCD=30;
  }
  // Auto-fire additionally fires automatically when there ARE enemies
  else if(autoFire&&nearest&&shootCD<=0){
    autoFireAt(nearest); shootCD=30;
  }
  if(iframes>0)iframes-=dt;
  if(shopEntryCooldown>0)shopEntryCooldown-=dt;
  // Safety death check every frame — can't miss it here
  if(p.hp<=0&&gState==='playing'){triggerDeath();return;}
  if(roomBanner.timer>0){roomBanner.timer-=dt;roomBanner.alpha=Math.min(1,roomBanner.timer);} else {roomBanner.alpha=0;}

  // ── DOOR TRANSITION ──
  // Player must walk fully past the wall edge to trigger
  checkDoors(p);

  // Powerup gem pickup
  const rm=curRoom();
  if(rm.puPending&&rm.cleared&&Math.hypot(p.x-W/2,p.y-H/2)<40){
    rm.puPending=false;openPowerupScreen();return;
  }
  // Exit portal — boss room after boss defeated
  if(rm._exitReady&&Math.hypot(p.x-W/2,p.y-H/2)<44){
    rm._exitReady=false;
    curLevel++;
    showLevelIntro();
    return;
  }

  // Update shopNearIdx — closest pedestal within range wins
  shopNearIdx=-1;
  if(curRoom().type==='shop'){
    let bestDist=90; // must be within 90px
    curRoom().shopItems.forEach((item,i)=>{
      const sx=W/2+((item.slot??i)-1)*210,sy=H/2;
      const d=Math.hypot(p.x-sx,p.y-sy);
      if(d<bestDist){bestDist=d;shopNearIdx=i;}
    });
  }
  // Shop purchase handled by keydown event only — not here, to prevent double-fire

  // Drops — splice in-place so the same array reference is always used
  for(let i=drops.length-1;i>=0;i--){
    const d=drops[i];
    if(Math.hypot(p.x-d.x,p.y-d.y)<50){
      drops.splice(i,1);
      if(d.type==='hp'){p.hp=Math.min(p.maxHp,p.hp+3);updateHUD();}
      else if(d.type==='score'){score+=d.val;updateHUD();}
      else if(d.type==='relic'){
        // Open the full choice screen rather than auto-applying one item
        openPowerupScreen();
      }
      const col=d.type==='hp'?'#2ECC71':d.type==='relic'?'#DAA520':'#FFD060';
      spawnParts(d.x,d.y,col,d.type==='relic'?30:14);
      showMsg(d.lbl,1800);
    }
  }

  enemies.forEach(e=>updateE(e,p,dt));

  bullets=bullets.filter(b=>{
    b.x+=b.vx*dt;b.y+=b.vy*dt;
    if(outBounds(b))return false;
    for(const o of rm.obstacles)if(b.x>o.x-o.w/2&&b.x<o.x+o.w/2&&b.y>o.y-o.h/2&&b.y<o.y+o.h/2)return false;
    for(let i=enemies.length-1;i>=0;i--){
      const e=enemies[i];
      if(Math.hypot(b.x-e.x,b.y-e.y)<e.sz+4){
        e.hp-=pStats.dmg;e._flash=1;spawnParts(b.x,b.y,e.col,4);
        if(e.hp<=0){
          score+=e.pts;spawnParts(e.x,e.y,e.col,e.boss?60:22);
          if(e.boss) bossDrop(e.x,e.y); else maybeDrop(e.x,e.y);
          enemies.splice(i,1);updateHUD();
        }
        return false;
      }
    }return true;
  });

  // Enemy bullets — manual loop so we can stop immediately on death
  for(let bi=eBullets.length-1;bi>=0;bi--){
    const b=eBullets[bi];
    b.x+=b.vx*dt;b.y+=b.vy*dt;
    let remove=false;
    if(outBounds(b)) remove=true;
    else{
      for(const o of rm.obstacles){
        if(b.x>o.x-o.w/2&&b.x<o.x+o.w/2&&b.y>o.y-o.h/2&&b.y<o.y+o.h/2){remove=true;break;}
      }
    }
    if(!remove&&iframes<=0&&Math.hypot(b.x-p.x,b.y-p.y)<p.size+5){
      p.hp--;
      iframes=22+pStats.xif;
      spawnParts(p.x,p.y,'#8B0000',8);
      updateHUD();
      remove=true;
      if(p.hp<=0){
        triggerDeath();
        return; // stop update() entirely right now
      }
    }
    if(remove) eBullets.splice(bi,1);
  }

  particles=particles.filter(p2=>{p2.x+=p2.vx*dt;p2.y+=p2.vy*dt;p2.life-=dt;return p2.life>0;});

  if(enemies.length===0&&!rm.cleared){
    if(rm.wavesLeft>0){
      // Spawn next wave
      rm.wavesLeft--;
      const lvl=LEVELS[curLevel];
      const waveSize=2+Math.floor(Math.random()*2);
      for(let w=0;w<waveSize;w++){
        const t=lvl.pool[Math.floor(Math.random()*lvl.pool.length)];
        let ex,ey;
        do{ex=PX1+70+Math.random()*(PX2-PX1-140);ey=PY1+70+Math.random()*(PY2-PY1-140);}
        while(Math.hypot(ex-W/2,ey-H/2)<160);
        enemies.push(mkE(t,ex,ey));
      }
      const waveNum=(rm.type==='combat'?2:1)-rm.wavesLeft;
      showMsg('⚡ WAVE '+(waveNum+1)+' — MORE INCOMING',2000);
      spawnParts(W/2,H/2,'#C41E1E',20);
    } else {
      rm.cleared=true;cleared.add(`${roomPos.x},${roomPos.y}`);onRoomClear(rm);
    }
  }
}

function updateE(e,p,dt){
  const cfg=ET[e.type];
  const ex=p.x-e.x,ey=p.y-e.y,dist=Math.hypot(ex,ey)||1;
  const orb=e.boss?200:120,spd=cfg.spd*(1+curLevel*.15);
  if(dist>orb){e.vx+=(ex/dist)*spd*.18;e.vy+=(ey/dist)*spd*.18;}
  else{e.vx+=(-ey/dist)*spd*.11;e.vy+=(ex/dist)*spd*.11;}
  enemies.forEach(e2=>{if(e2===e)return;const sep=Math.hypot(e.x-e2.x,e.y-e2.y)||1;if(sep<42){e.vx+=(e.x-e2.x)/sep*1.4;e.vy+=(e.y-e2.y)/sep*1.4;}});
  const ms=spd*(e.boss?1.9:2.6),sp=Math.hypot(e.vx,e.vy);
  if(sp>ms){e.vx=e.vx/sp*ms;e.vy=e.vy/sp*ms;}
  e.vx*=.87;e.vy*=.87;
  e.x=clamp(e.x+e.vx*dt,PX1+e.sz+3,PX2-e.sz-3);
  e.y=clamp(e.y+e.vy*dt,PY1+e.sz+3,PY2-e.sz-3);
  e.stimer-=dt;
  if(e.stimer<=0){
    e.stimer=cfg.sr+Math.random()*40;
    const shots=e.boss?3:1;
    for(let i=0;i<shots;i++){
      const sp2=e.boss?(i-1)*.26:0,a=Math.atan2(p.y-e.y,p.x-e.x)+sp2;
      eBullets.push({x:e.x,y:e.y,vx:Math.cos(a)*cfg.bs,vy:Math.sin(a)*cfg.bs,enemy:true,col:e.col});
    }
  }
}

// ── DOOR CHECK ────────────────────────────────────────────────
// Player movement is clamped to the play area, so we can never
// test "past the wall". Instead: trigger when the player is within
// TRIGGER_DIST of the wall edge AND centered on the door opening.
function checkDoors(p){
  const rm=curRoom();if(!rm||!rm.cleared)return;
  const hw=DHW+12;
  const mid=WT/2;

  // Always verify destination room exists before moving
  const destExists=(ddx,ddy)=>{
    const nx=roomPos.x+ddx, ny=roomPos.y+ddy;
    return nx>=0&&nx<GW&&ny>=0&&ny<GH&&dungeonGrid[ny]?.[nx];
  };

  if(rm.doors.U && p.y<=PY1-mid && Math.abs(p.x-W/2)<hw && destExists(0,-1))
    { moveRoom(0,-1,W/2,PY2-p.size-10); return; }
  if(rm.doors.D && p.y>=PY2+mid && Math.abs(p.x-W/2)<hw && destExists(0,1))
    { moveRoom(0,1,W/2,PY1+p.size+10); return; }
  if(rm.doors.L && p.x<=PX1-mid && Math.abs(p.y-H/2)<hw && destExists(-1,0))
    { moveRoom(-1,0,PX2-p.size-10,H/2); return; }
  if(rm.doors.R && p.x>=PX2+mid && Math.abs(p.y-H/2)<hw && destExists(1,0))
    { moveRoom(1,0,PX1+p.size+10,H/2); return; }
}

function moveRoom(ddx,ddy,nx,ny){
  roomPos.x+=ddx;roomPos.y+=ddy;
  const key=`${roomPos.x},${roomPos.y}`;
  const wasVisited=visited.has(key);
  visited.add(key);
  const rm=curRoom();
  // Only load enemies if room hasn't been cleared — no respawns on revisit
  enemies=rm.cleared?[]:[...rm.enemies];
  drops=[];bullets=[];eBullets=[];
  shopNearIdx=-1; // reset on room entry — no stale purchases
  player.x=nx;player.y=ny;
  updateHUD();
  // If entering a shop, put player at centre and add entry cooldown
  if(rm.type==='shop'){player.x=W/2;player.y=H/2+80;shopEntryCooldown=45;}
  // Tick powerup durability — only when entering a room for the first time
  if(!wasVisited && rm.type!=='start'){
    pPowerups=pPowerups.filter(entry=>{
      if(entry.roomsLeft>=99) return true; // permanent
      entry.roomsLeft--;
      if(entry.roomsLeft<=0){
        const pu=PUS.find(x=>x.id===entry.id);
        if(pu) reverseEffect(pu);
        showMsg('⚠ '+((PUS.find(x=>x.id===entry.id)||{}).nm||entry.id)+' EXPIRED',2000);
        return false;
      }
      return true;
    });
  }
  _lastInvKey=''; // force inventory redraw
  updateHUD();
  const names={start:'SAFE ROOM',combat:rm.cleared?'ALREADY CLEARED':'DANGER AHEAD',boss:rm.cleared?'BOSS DEFEATED':'BOSS LAIR',shop:'CURSED MERCHANT',powerup:'RELIC CHAMBER'};
  showMsg('— '+(names[rm.type]||'UNKNOWN CHAMBER')+' —',1600);
  // Show enemy type banner
  if(!rm.cleared&&rm.enemies.length>0){
    const types=[...new Set(rm.enemies.map(e=>e.type))];
    const mainType=ET[types[0]];
    const hint=SCAM_HINTS[types[0]]||'';
    roomBanner.text=mainType?mainType.lbl+' ATTACK':'ENEMIES AHEAD';
    roomBanner.sub=mainType?mainType.tip:'Stay alert.';
    roomBanner.alpha=1;roomBanner.timer=4.5;
  }
}

function togglePause(){
  if(gState==='playing'){gState='paused';show('sPAUSE');}
  else if(gState==='paused'){resumeGame();}
}
function resumeGame(){
  hide('sPAUSE');gState='playing';
}

function updateFireModeHUD(){
  const btn=document.getElementById('fireModeBtn');
  if(!btn)return;
  if(autoFire){
    btn.textContent='AUTO-FIRE: ON';
    btn.style.background='rgba(139,0,0,.4)';
    btn.style.borderColor='var(--blood2)';
    btn.style.color='var(--blood2)';
  } else {
    btn.textContent='MANUAL: SPACE';
    btn.style.background='rgba(184,134,11,.3)';
    btn.style.borderColor='#DAA520';
    btn.style.color='#FFD060';
  }
}

function autoFireAt(target){
  if(!player)return;
  const p=player;
  const a=Math.atan2(target.y-p.y,target.x-p.x);
  const spd=9;
  const fire=ang=>bullets.push({x:p.x,y:p.y,vx:Math.cos(ang)*spd,vy:Math.sin(ang)*spd,enemy:false});
  fire(a);
  if(pStats.tri){fire(a-.26);fire(a+.26);}
  if(hasPU('bookmark')) fire(a+.52);
}

// Legacy manual fire (kept for gamepad trigger)
function fireBullet(){
  if(!player||enemies.length===0)return;
  let nearest=null,nd=Infinity;
  enemies.forEach(e=>{const d=Math.hypot(e.x-player.x,e.y-player.y);if(d<nd){nd=d;nearest=e;}});
  if(nearest) autoFireAt(nearest);
}

function maybeDrop(x,y){
  if(Math.random()<.35){
    const hp=Math.random()<.5;
    drops.push({
      x:x+(Math.random()*24-12),
      y:y+(Math.random()*24-12),
      type:hp?'hp':'score',
      val:20,
      lbl:hp?'+2 INTEGRITY':'+20 pts'
    });
  }
}

function bossDrop(x,y){
  // Guaranteed: 2 score drops + 1 health + 1 relic powerup
  for(let i=0;i<2;i++){
    drops.push({x:x+Math.cos(i*2.4)*55,y:y+Math.sin(i*2.4)*55,
      type:'score',val:80,lbl:'+80 SOULS'});
  }
  drops.push({x:x,y:y-40,type:'hp',val:0,lbl:'+3 INTEGRITY'});
  // Relic drop — special gold pickup that grants a random powerup
  const avail=PUS.filter(p=>!hasPU(p.id));
  if(avail.length>0){
    const pu=avail[Math.floor(Math.random()*avail.length)];
    drops.push({x:x,y:y+50,type:'relic',val:0,lbl:'RELIC: '+pu.nm,puId:pu.id});
  }
  showMsg('☠ BOSS DEFEATED — COLLECT YOUR SPOILS',2500);
}

function spawnParts(x,y,color,n){
  for(let i=0;i<n;i++){
    const a=Math.random()*Math.PI*2,s=1+Math.random()*3.5;
    particles.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,color,sz:2+Math.random()*3,life:16+Math.random()*18,maxLife:34});
  }
}

// ── ROOM CLEAR ────────────────────────────────────────────────
const TIPS={
  phish_email:'Phishing emails mimic Ledger Wallet precisely. Bookmark ledger.com and never click links in emails claiming to be from Ledger.',
  scam_letter:'Physical scam letters are real. Ledger never sends postal mail asking you to verify your device or phrase.',
  fake_support:'Fake support agents find victims through search results. Only support.ledger.com is real — Ledger never DMs you first.',
  social_eng:'Social engineers invest weeks building trust before striking. Your Secret Recovery Phrase is for your eyes only — always.',
  addr_poison:'Address poisoners plant near-identical addresses in your history. Verify every single character before confirming any send.',
  dust_token:'Dusted tokens are surveillance tools. Ignore all unsolicited tokens — never swap, transfer, or approve them.',
  boss_phisher:'Industrial phishing mimics the entire Ledger Wallet site. Use bookmarks and run the Genuine Check on every device.',
  boss_support:'Fake call-center operations run entire support desks. Your Secret Recovery Phrase is never needed — not even by real Ledger.',
  boss_dust:'Coordinated dusting and address poisoning map entire portfolios. Hardware verification and full address checks defeat both.',
};

function onRoomClear(rm){
  const types=[...new Set(rm.enemies.map(e=>e.type))];
  const tip=types.length&&TIPS[types[0]]?TIPS[types[0]]:'Remain vigilant. Deeper floors bring stronger threats.';
  const boss=rm.type==='boss';
  const last=boss&&curLevel>=LEVELS.length-1;
  if(boss){
    document.getElementById('cTitle').textContent=last?'⚡ THE ARCHITECT FALLS':'⚡ FLOOR BOSS DEFEATED';
    const nextFloor=!last?LEVELS[curLevel+1]:null;
    document.getElementById('cSub').textContent=last
      ?'THE VAULT IS SEALED FOREVER'
      :'A PORTAL HAS OPENED — DESCEND WHEN READY';
    document.getElementById('cText').textContent=last
      ?tip
      :'Floor '+(curLevel+1)+' complete. '+tip+(nextFloor?' Next: '+nextFloor.tip:'');
    document.getElementById('cBtn').querySelector('span').textContent=last?'⚔ CLAIM VICTORY':'↩ RETURN TO DUNGEON';
  } else {
    document.getElementById('cTitle').textContent='☩ ROOM PURGED';
    document.getElementById('cSub').textContent='THREAT NEUTRALIZED';
    document.getElementById('cText').textContent=tip;
    document.getElementById('cBtn').querySelector('span').textContent='CONTINUE →';
  }
  gState='clear';show('sCLEAR');
}

function dismissClear(){
  hide('sCLEAR');const rm=curRoom();
  if(rm.type==='boss'){
    if(curLevel<LEVELS.length-1){
      // Don't jump floors yet — place the exit portal, let player explore first
      rm._exitReady=true;
      gState='playing';
      showMsg('⬇ A DESCENT PORTAL HAS OPENED — FIND IT TO DESCEND',3000);
      return;
    }
    else{triggerWin();return;}
  }
  gState='playing';
}

function openPowerupScreen(){
  gState='pu';
  const avail=PUS.filter(p=>!hasPU(p.id)).sort(()=>Math.random()-.5).slice(0,3);
  const cont=document.getElementById('puChoices');cont.innerHTML='';
  if(avail.length===0){
    // Already owns everything — show a message and a big score bonus instead
    const msg=document.createElement('div');
    msg.style.cssText='text-align:center;padding:20px;font-family:Creepster,cursive;';
    msg.innerHTML='<div style="font-size:28px;color:#FFD060;margin-bottom:10px">⚡ FULLY PROTECTED ⚡</div>'
      +'<div style="font-size:13px;color:#C8BFA8;line-height:1.8">You carry every defense.<br>The dungeon rewards your mastery.</div>'
      +'<div style="font-size:22px;color:#FFD060;margin-top:14px">+500 SOULS</div>';
    cont.appendChild(msg);
    score+=500;updateHUD();
    // Auto-dismiss after 2.5s
    setTimeout(()=>{if(gState==='pu'){hide('sPU');gState='playing';}},2500);
  } else {
    avail.forEach(pu=>{
      const d=document.createElement('div');d.className='pu-card';
      d.innerHTML=`<div class="pu-ico">${pu.ic}</div><div class="pu-nm">${pu.nm}</div>`
        +`<div style="font-size:11px;color:#66FF88;margin:4px 0;font-family:'Share Tech Mono',monospace;">${pu.game||''}</div>`
        +`<div class="pu-dc">${(pu.desc||'').replace('Real tip: ','')}</div>`;
      d.onclick=()=>{applyPU(pu);hide('sPU');gState='playing';flashPU(pu);};
      cont.appendChild(d);
    });
  }
  show('sPU');
}

function reverseEffect(pu){
  // Undo the stat bonus when a timed powerup expires
  const p=player;if(!p)return;
  if(pu.eff==='maxhp+2'){p.maxHp=Math.max(10,p.maxHp-2);p.hp=Math.min(p.hp,p.maxHp);}
  else if(pu.eff==='spd+.5') pStats.spd=Math.max(3.5,pStats.spd-.5);
  else if(pu.eff==='dmg+.5') pStats.dmg=Math.max(1,pStats.dmg-.5);
  else if(pu.eff==='dmg+1') pStats.dmg=Math.max(1,pStats.dmg-1);
  else if(pu.eff==='hp+3'){p.maxHp=Math.max(10,p.maxHp-3);p.hp=Math.min(p.hp,p.maxHp);}
  else if(pu.eff==='shield') pStats.xif=Math.max(0,pStats.xif-20);
  else if(pu.eff==='iframes+25') pStats.xif=Math.max(0,pStats.xif-25);
  else if(pu.eff==='tri') pStats.tri=hasPU('multisig'); // only keep if still owned
}

function puDuration(source){
  // 'relic'=room pickup=5 rooms, 'boss'=boss drop=3 rooms, 'shop'=permanent
  if(source==='boss') return 3;
  if(source==='relic') return 5;
  return 99; // shop = effectively permanent
}
function hasPU(id){ return pPowerups.some(p=>p.id===id); }
function applyPU(pu,source='relic'){
  if(hasPU(pu.id))return;
  pPowerups.push({id:pu.id,roomsLeft:puDuration(source)});const p=player;
  if(pu.eff==='maxhp+2'){p.maxHp+=2;p.hp=Math.min(p.hp+2,p.maxHp);}
  else if(pu.eff==='spd+.5') pStats.spd+=.5;
  else if(pu.eff==='dmg+1') pStats.dmg+=1;
  else if(pu.eff==='dmg+.5') pStats.dmg+=.5;
  else if(pu.eff==='hp+3'){p.maxHp+=3;p.hp=Math.min(p.hp+3,p.maxHp);}
  else if(pu.eff==='shield') pStats.xif+=20;
  else if(pu.eff==='iframes+25') pStats.xif+=25;
  else if(pu.eff==='tri') pStats.tri=true;
  updateHUD();
}

function flashPU(pu){
  document.getElementById('puPopI').textContent=pu.ic;
  document.getElementById('puPopN').textContent=pu.nm;
  document.getElementById('puPopG').textContent='▶ '+(pu.game||'');
  document.getElementById('puPopD').textContent=pu.desc||'';
  const el=document.getElementById('puPop');el.style.opacity=1;
  setTimeout(()=>el.style.opacity=0,4000);
}

function updateHUD(){
  if(!player)return;
  const pct=player.hp/player.maxHp*100;
  document.getElementById('hpFill').style.width=pct+'%';
  document.getElementById('hpFill').style.background=pct>40?`linear-gradient(to right,#8B0000,#C41E1E)`:pct>20?`linear-gradient(to right,#6B3000,#AA4400)`:`linear-gradient(to right,#3A0000,#880000)`;
  document.getElementById('scoreD').textContent=score.toLocaleString();
  document.getElementById('floorD').textContent=LEVELS[curLevel].floor;
  const d2=FLOOR_DIFF[Math.min(curLevel,FLOOR_DIFF.length-1)];
  document.getElementById('diffD').textContent=d2.label;
  document.getElementById('progFill').style.width=((curLevel+1)/LEVELS.length*100)+'%';
  document.getElementById('progLbl').textContent='FLOOR '+(curLevel+1)+' OF '+LEVELS.length;
  const rm=curRoom();
  // Inventory panel — only rebuild if contents changed (prevents flash on every kill)
  const invKey=pPowerups.map(p=>p.id+':'+p.roomsLeft).join(',');
  if(invKey!==_lastInvKey){
    _lastInvKey=invKey;
    const inv=document.getElementById('invSlots');
    if(inv){
      inv.innerHTML='';
      if(pPowerups.length===0){
        const empty=document.createElement('div');empty.className='inv-empty';
        empty.textContent='NO DEFENSES YET';inv.appendChild(empty);
      } else {
        pPowerups.forEach(entry=>{
        const pu=PUS.find(x=>x.id===entry.id);if(!pu)return;
        const perm=entry.roomsLeft>=99;
        const pct=perm?100:Math.round((entry.roomsLeft/5)*100);
        const bc=entry.roomsLeft<=1?'#FF4444':entry.roomsLeft<=2?'#FF8800':'#66FF88';
        const durTxt=perm?'PERMANENT':entry.roomsLeft+' room'+(entry.roomsLeft!==1?'s':'')+' left';
        const row=document.createElement('div');row.className='inv-item';
        row.innerHTML='<span class="inv-icon">'+pu.ic+'</span>'
          +'<div class="inv-text">'
          +'<div class="inv-name">'+pu.nm+'</div>'
          +'<div class="inv-eff">'+(pu.game||'')+'</div>'
          +'<div style="margin-top:2px;height:3px;background:#1A1020;border-radius:2px;overflow:hidden;">'
          +'<div style="height:100%;width:'+pct+'%;background:'+bc+';border-radius:2px;"></div></div>'
          +'<div style="font-size:7px;color:'+bc+';font-family:Share Tech Mono,monospace;">'+durTxt+'</div>'
          +'</div>';
        inv.appendChild(row);
      });
      }
    }
  }
}

